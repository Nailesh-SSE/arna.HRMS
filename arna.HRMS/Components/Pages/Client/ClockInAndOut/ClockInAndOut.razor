@using arna.HRMS.Components.Loader
@using arna.HRMS.Components.Pages.Attendance
@using arna.HRMS.Components.lib.components.ui.Forms
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels.Attendance
@using arna.HRMS.Services
@using arna.HRMS.Services.Auth
@using System.Text.Json.Serialization

@implements IDisposable
@inject IAttendanceService ClockService
@inherits AuthenticatedLayoutBase
@inject IJSRuntime JS

<Loader Visible="@IsLoading" Message="@LoaderMessage" />

<div class="d-flex align-items-center gap-2 flex-wrap">
    @if (IsEmployee())
    {
        <!-- ── Status Pill ── -->
        <span class="d-inline-flex align-items-center gap-1 rounded-pill border
                         px-2 py-1 @(IsClockedIn
                                       ? "bg-success bg-opacity-10 border-success border-opacity-25"
                                       : "bg-light")">
        <span class="clock-status-dot d-inline-block rounded-circle
                         @(IsClockedIn ? "bg-success" : "bg-secondary")"></span>
    </span>

        <!-- ── First Clock-In (always visible once set, never changes during the day) ── -->
    @if (!string.IsNullOrEmpty(FirstClockInDisplay))
        {
            <span class="d-none d-sm-inline-flex align-items-center gap-1
                                 rounded-pill border px-2 py-1 bg-light"
                  title="First clock-in today">
                <small class="clock-label-text fw-bold text-success">ClockIN</small>
                <small class="fw-semibold font-monospace">@FirstClockInDisplay</small>
            </span>
        }

        <!-- ── Last Clock-Out (updates each time user clocks out) ── -->
        @if (!string.IsNullOrEmpty(LastClockOutDisplay))
        {
            <span class="d-none d-md-inline-flex align-items-center gap-1
                                 rounded-pill border px-2 py-1 bg-light"
                  title="Last clock-out today">
                <small class="clock-label-text fw-bold text-danger">ClockOUT</small>
                <small class="fw-semibold font-monospace">@LastClockOutDisplay</small>
            </span>
        }

        <!-- ── Session Timer (runs from latest clock-in) ── -->
        @if (IsClockedIn)
        {
            <span class="d-inline-flex align-items-center gap-1 rounded-pill border
                                 px-2 py-1 bg-primary bg-opacity-10 border-primary border-opacity-25"
                  title="Current session duration">
                <i class="bi bi-stopwatch text-primary clock-stopwatch-icon"></i>
                <small class="fw-semibold font-monospace text-primary">@SessionDuration</small>
            </span>
        }

        <!-- ── Action Button ── -->
        @if (IsClockedIn)
        {
            <AppButton ButtonClass="btn btn-outline-danger btn-sm rounded-pill"
                       Disabled="@DisableClockOut"
                       OnClick="ClockOutAsync">
                <i class="bi bi-stop-circle"></i>
                <span class="d-none d-sm-inline ms-1">ClockOut</span>
            </AppButton>
        }
        else
        {
            <AppButton ButtonClass="btn btn-success btn-sm rounded-pill"
                       Disabled="@DisableClockIn"
                       OnClick="ClockInAsync">
                <i class="bi bi-play-circle @(IsClockInOut ? "clock-alert" : "")"></i>
                <span class="d-none d-sm-inline ms-1">ClockIn</span>
            </AppButton>
        }
    }
</div>

@* ── Note Form Modal ── *@
@if (ShowDynamicForm)
{
    <div class="clock-modal-overlay position-fixed top-0 start-0 w-100 h-100
                    d-flex align-items-center justify-content-center">
        <div class="clock-modal-card bg-white rounded-3 shadow-lg mx-3 p-4">
            <ClockInAndOutMessage Model="attendanceViewModel"
                                  OnSubmit="SubmitClockInOutAsync"
                                  OnCancel="CloseForm" />
        </div>
    </div>
}

@* ── Toast ── *@
@if (ShowToast)
{
    <div class="clock-toast-wrapper position-fixed bottom-0 end-0 p-3">
        <div class="toast show border-0 shadow-lg rounded-3 bg-white" role="alert">
            <div class="toast-body d-flex align-items-center gap-2 py-3 px-3">
                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                <span>@ToastMessage</span>
            </div>
        </div>
    </div>
}

@code {

    // ── Form ──
    private AttendanceViewModel attendanceViewModel = new();

    // ── Core State ──
    private bool IsClockedIn;
    private bool? PendingClockIn;
    private bool DisableClockOut;
    private bool DisableClockIn;
    public bool IsClockInOut;

    // ── Time Tracking ──
    private TimeOnly In;
    private TimeOnly Out;
    private TimeOnly AccumulatedHours;
    private TimeOnly LastClockInTime;

    // ── API fallback values (used when localStorage is empty) ──
    private TimeSpan? _apiClockIn;
    private TimeSpan? _apiClockOut;

    // ── Display Strings ──
    private string? FirstClockInDisplay;
    private string? LastClockOutDisplay;
    private string SessionDuration = "00:00:00";

    // ── UI Flags ──
    private bool ShowDynamicForm;
    private bool ShowToast;
    private string ToastMessage = "";
    private bool IsLoading;
    private string LoaderMessage = "";

    // ── Location ──
    private double? CurrentLatitude;
    private double? CurrentLongitude;
    private bool IsGettingLocation;

    // ── Timers ──
    private CancellationTokenSource? _cts;
    private CancellationTokenSource? _clockOutCooldownCts;
    private bool _jsReady;

    // ─────────────────────────────────────────────
    //  LIFECYCLE
    // ─────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        StartSessionTimer();

        var employeeId = GetEmployeeId();
        if (employeeId == 0) return;

        var lastEntry = await ClockService.GetClockStatusAsync(employeeId);
        if (!lastEntry.IsSuccess || lastEntry.Data == null) return;

        var data = lastEntry.Data;

        if (data.Date.Date == DateTime.Today)
        {
            // ── Store API values as fallback for localStorage restore ──
            _apiClockIn = data.ClockInTime;
            _apiClockOut = data.ClockOutTime;

            if (data.ClockInTime != null && data.ClockOutTime == null)
            {
                // Currently clocked in
                IsClockedIn = true;
                In = TimeOnly.FromTimeSpan(data.ClockInTime.Value);
                LastClockInTime = In;

                var elapsed = (DateTime.Now - DateTime.Today.Add(In.ToTimeSpan())).TotalSeconds;
                if (elapsed < 60)
                    _ = StartClockOutCooldownAsync((int)(60 - elapsed));
                else
                    DisableClockOut = false;
            }
            else
            {
                // Already clocked out or no active session
                IsClockedIn = false;
            }
        }
        else if (data.ClockInTime != null
                 && data.ClockOutTime == null
                 && data.Date.Date < DateTime.Today)
        {
            // Pending clock-out from a previous day
            IsClockedIn = false;
            IsClockInOut = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _jsReady = true;
        await RestoreFromStorage();
        StateHasChanged();
    }

    // ─────────────────────────────────────────────
    //  LOCAL STORAGE
    // ─────────────────────────────────────────────

    private async Task PersistToStorage()
    {
        if (!_jsReady) return;
        try
        {
            await JS.InvokeVoidAsync("clockState.save", new
            {
                date = DateTime.Today.ToString("yyyy-MM-dd"),
                firstClockIn = FirstClockInDisplay,
                lastClockOut = LastClockOutDisplay,
                lastClockIn = LastClockInTime.ToString("HH:mm:ss"),
                isClockedIn = IsClockedIn
            });
        }
        catch { }
    }

    private async Task RestoreFromStorage()
    {
        try
        {
            var state = await JS.InvokeAsync<ClockStateDto?>("clockState.load");
            var today = DateTime.Today.ToString("yyyy-MM-dd");

            if (state != null && state.Date == today)
            {
                // ── Restore from localStorage ──
                if (!string.IsNullOrEmpty(state.FirstClockIn))
                    FirstClockInDisplay = state.FirstClockIn;

                if (!string.IsNullOrEmpty(state.LastClockOut))
                    LastClockOutDisplay = state.LastClockOut;

                // Restore LastClockInTime for session timer
                if (!string.IsNullOrEmpty(state.LastClockIn)
                    && TimeOnly.TryParse(state.LastClockIn, out var parsed))
                {
                    LastClockInTime = parsed;
                    In = parsed;
                }
            }
            else
            {
                // Stale data — clear
                await JS.InvokeVoidAsync("clockState.clear");
            }

            // ── Fallback: seed from API if localStorage was empty ──
            if (string.IsNullOrEmpty(FirstClockInDisplay) && _apiClockIn.HasValue)
                FirstClockInDisplay = TimeOnly.FromTimeSpan(_apiClockIn.Value).ToString("hh:mm tt");

            if (string.IsNullOrEmpty(LastClockOutDisplay) && _apiClockOut.HasValue)
                LastClockOutDisplay = TimeOnly.FromTimeSpan(_apiClockOut.Value).ToString("hh:mm tt");

            // If currently clocked in but still no FirstClockIn, use current session
            if (IsClockedIn && string.IsNullOrEmpty(FirstClockInDisplay))
                FirstClockInDisplay = LastClockInTime.ToString("hh:mm tt");

            await PersistToStorage();
        }
        catch { }
    }

    private sealed class ClockStateDto
    {
        [JsonPropertyName("date")] public string? Date { get; set; }
        [JsonPropertyName("firstClockIn")] public string? FirstClockIn { get; set; }
        [JsonPropertyName("lastClockOut")] public string? LastClockOut { get; set; }
        [JsonPropertyName("lastClockIn")] public string? LastClockIn { get; set; }
        [JsonPropertyName("isClockedIn")] public bool IsClockedIn { get; set; }
    }

    // ─────────────────────────────────────────────
    //  CLOCK ACTIONS
    // ─────────────────────────────────────────────

    private async Task ClockInAsync()
    {
        PendingClockIn = true;
        DisableClockIn = true;
        await LogDevice();
        await PrepareClockActionAsync();
    }

    private async Task ClockOutAsync()
    {
        if (DisableClockOut) return;
        PendingClockIn = false;
        await LogDevice();
        await PrepareClockActionAsync();
    }

    private void OpenNoteForm()
    {
        attendanceViewModel = new AttendanceViewModel();
        ShowDynamicForm = true;
    }

    private void CloseForm()
    {
        ShowDynamicForm = false;
        if (PendingClockIn == true) DisableClockIn = false;
    }

    private async Task SubmitClockInOutAsync()
    {
        if (CurrentLatitude == null || CurrentLongitude == null)
        {
            await ShowNotification("Location is required");
            return;
        }

        ShowDynamicForm = false;

        try
        {
            await SetLoading(true, PendingClockIn == true ? "Clocking in…" : "Clocking out…");

            var employeeId = GetEmployeeId();
            if (employeeId == 0) return;

            var device = await JS.InvokeAsync<string>("deviceHelper.getDeviceType");

            if (PendingClockIn == true)
            {
                // ──── CLOCK IN ────
                In = TimeOnly.FromDateTime(DateTime.Now);
                LastClockInTime = In;
                IsClockedIn = true;

                // First clock-in of the day — set ONLY ONCE, never overwrite
                if (string.IsNullOrEmpty(FirstClockInDisplay))
                    FirstClockInDisplay = In.ToString("hh:mm tt");

                var result = await ClockService.CreateAttendanceAsync(new AttendanceViewModel
                {
                    EmployeeId = employeeId,
                    Date = DateTime.Today,
                    ClockInTime = In.ToTimeSpan(),
                    StatusId = AttendanceStatus.Present,
                    Notes = attendanceViewModel.Notes,
                    WorkingHours = TimeSpan.Zero,
                    Latitude = CurrentLatitude,
                    Longitude = CurrentLongitude,
                    Device = device
                });

                if (!result.IsSuccess)
                {
                    IsClockedIn = false;
                    DisableClockIn = false;
                    await ShowNotification(result.Message ?? "Clock-In failed");
                    return;
                }

                AccumulatedHours = new TimeOnly(0, 0);
                _ = StartClockOutCooldownAsync(60);
                await PersistToStorage();
                await ShowNotification($"Clocked in at {In:hh:mm tt}");
            }
            else
            {
                // ──── CLOCK OUT ────
                Out = TimeOnly.FromDateTime(DateTime.Now);
                IsClockedIn = false;
                DisableClockIn = false;
                IsClockInOut = false;

                // Update last clock-out display
                LastClockOutDisplay = Out.ToString("hh:mm tt");

                var worked = Out.ToTimeSpan() - In.ToTimeSpan();
                AccumulatedHours = AccumulatedHours.Add(worked);

                var result = await ClockService.CreateAttendanceAsync(new AttendanceViewModel
                {
                    EmployeeId = employeeId,
                    Date = DateTime.Today,
                    ClockOutTime = Out.ToTimeSpan(),
                    StatusId = AttendanceStatus.Present,
                    Notes = attendanceViewModel.Notes,
                    WorkingHours = AccumulatedHours.ToTimeSpan(),
                    Latitude = CurrentLatitude,
                    Longitude = CurrentLongitude,
                    Device = device
                });

                if (!result.IsSuccess)
                {
                    await ShowNotification(result.Message ?? "Clock-Out failed");
                    return;
                }

                await PersistToStorage();
                await ShowNotification($"Clocked out at {Out:hh:mm tt}");
            }

            CurrentLatitude = null;
            CurrentLongitude = null;
        }
        finally
        {
            await SetLoading(false);
        }
    }

    private void StartSessionTimer()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _ = Task.Run(async () =>
        {
            try
            {
                while (await timer.WaitForNextTickAsync(ct))
                {
                    if (!IsClockedIn) continue;

                    var elapsed = DateTime.Now.TimeOfDay - LastClockInTime.ToTimeSpan();
                    if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;
                    SessionDuration = elapsed.ToString(@"hh\:mm\:ss");

                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
            finally { timer.Dispose(); }
        }, ct);
    }

    private async Task StartClockOutCooldownAsync(int seconds)
    {
        _clockOutCooldownCts?.Cancel();
        _clockOutCooldownCts = new CancellationTokenSource();
        var ct = _clockOutCooldownCts.Token;

        DisableClockOut = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(seconds), ct);
            DisableClockOut = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    private async Task<bool> PrepareClockActionAsync()
    {
        try
        {
            await SetLoading(true, "Getting location…");
            IsGettingLocation = true;

            var location = await ClockService.GetCurrentLocationAsync();
            IsGettingLocation = false;

            if (location == null)
            {
                DisableClockIn = false;
                DisableClockOut = false;
                await ShowNotification("Location permission is required");
                return false;
            }

            CurrentLatitude = location.Value.Latitude;
            CurrentLongitude = location.Value.Longitude;

            OpenNoteForm();
            return true;
        }
        finally
        {
            await SetLoading(false);
        }
    }

    private async Task LogDevice()
    {
        var device = await JS.InvokeAsync<string>("deviceHelper.getDeviceType");
        await JS.InvokeVoidAsync("console.log", $"Device: {device}");
    }

    private async Task ShowNotification(string message)
    {
        ToastMessage = message;
        ShowToast = true;
        await InvokeAsync(StateHasChanged);

        try { await Task.Delay(2500); }
        catch (OperationCanceledException) { }

        ShowToast = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetLoading(bool show, string msg = "")
    {
        IsLoading = show;
        LoaderMessage = show ? msg : "";
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _clockOutCooldownCts?.Cancel();
        _clockOutCooldownCts?.Dispose();
    }
}