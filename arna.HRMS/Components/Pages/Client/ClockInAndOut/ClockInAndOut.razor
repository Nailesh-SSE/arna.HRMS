@using arna.HRMS.Components.Loader
@using arna.HRMS.Components.Pages.Attendance
@using arna.HRMS.Components.lib.components.ui.Forms
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels.Attendance
@using arna.HRMS.Services
@using arna.HRMS.Services.Auth
@using System.Text.Json.Serialization

@implements IDisposable
@inject IAttendanceService ClockService
@inherits AuthenticatedLayoutBase
@inject IJSRuntime JS

<Loader Visible="@IsLoading" Message="@LoaderMessage" />

<div class="clock-container d-flex align-items-center gap-2 flex-wrap">
    @if (IsEmployee())
    {
        @if (!string.IsNullOrEmpty(FirstClockInDisplay))
        {
            <span class="clock-info-pill clock-info-pill--in" title="First clock-in today">
                <small class="clock-info-label text-success">ClockIn</small>
                <small class="clock-info-time">@FirstClockInDisplay</small>
            </span>
        }

        @if (!string.IsNullOrEmpty(LastClockOutDisplay))
        {
            <span class="clock-info-pill clock-info-pill--out" title="Last clock-out today">
                <small class="clock-info-label text-danger">ClockOut</small>
                <small class="clock-info-time">@LastClockOutDisplay</small>
            </span>
        }

        @if (IsClockedIn)
        {
            <span class="clock-session-pill" title="Current session duration">
                <i class="bi bi-stopwatch clock-stopwatch-icon text-primary"></i>
                <small class="clock-session-time">@SessionDuration</small>
            </span>

            <AppButton ButtonClass="btn btn-outline-danger btn-sm rounded-pill clock-action-btn"
                       Disabled="@DisableClockOut"
                       OnClick="ClockOutAsync">
                <i class="bi bi-stop-circle"></i>
                <span class="ms-1">ClockOut</span>
            </AppButton>
        }
        else
        {
            <AppButton ButtonClass="btn btn-success btn-sm rounded-pill clock-action-btn"
                       Disabled="@DisableClockIn"
                       OnClick="ClockInAsync">
                <i class="bi bi-play-circle @(IsClockInOut ? "clock-alert" : "")"></i>
                <span class="ms-1">ClockIn</span>
            </AppButton>
        }
    }
</div>

@if (ShowDynamicForm)
{
    <div class="clock-modal-overlay position-fixed top-0 start-0 w-100 h-100
                    d-flex align-items-center justify-content-center">
        <div class="clock-modal-card bg-white rounded-3 shadow-lg mx-3 p-4">
            <ClockInAndOutMessage Model="attendanceViewModel"
                                  OnSubmit="SubmitClockInOutAsync"
                                  OnCancel="CloseForm" />
        </div>
    </div>
}

@if (ShowToast)
{
    <div class="clock-toast-wrapper position-fixed bottom-0 end-0 p-3">
        <div class="toast show border-0 shadow-lg rounded-3 bg-white" role="alert">
            <div class="toast-body d-flex align-items-center gap-2 py-3 px-3">
                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                <span>@ToastMessage</span>
            </div>
        </div>
    </div>
}

@code {
    private AttendanceViewModel attendanceViewModel = new();

    private bool IsClockedIn;
    private bool? PendingClockIn;
    private bool DisableClockOut;
    private bool DisableClockIn;
    private bool IsClockInOut;
    private bool ShowDynamicForm;
    private bool ShowToast;
    private bool IsLoading;
    private bool _jsReady;

    private TimeOnly In;
    private TimeOnly Out;
    private TimeOnly AccumulatedHours;
    private TimeOnly LastClockInTime;

    private TimeSpan? _apiClockIn;
    private TimeSpan? _apiClockOut;

    private string? FirstClockInDisplay;
    private string? LastClockOutDisplay;
    private string SessionDuration = "00:00:00";
    private string ToastMessage = "";
    private string LoaderMessage = "";

    private double? CurrentLatitude;
    private double? CurrentLongitude;

    private CancellationTokenSource? _cts;
    private CancellationTokenSource? _cooldownCts;

    private const int CooldownSeconds = 60;
    private const int ToastMs = 2500;
    private const string DisplayFmt = "hh:mm tt";
    private const string ParseFmt = "HH:mm:ss";
    private const string DateFmt = "yyyy-MM-dd";

    private string StatusPillClass => IsClockedIn ? "clock-status--active" : "clock-status--inactive";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        StartSessionTimer();

        var id = GetEmployeeId();
        if (id > 0) await LoadClockStatusAsync(id);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _jsReady = true;
        await RestoreFromStorage();
        StateHasChanged();
    }

    private async Task LoadClockStatusAsync(int employeeId)
    {
        var result = await ClockService.GetClockStatusAsync(employeeId);
        if (!result.IsSuccess || result.Data is null) return;

        var data = result.Data;

        if (data.Date.Date == DateTime.Today)
        {
            _apiClockIn = data.ClockInTime;
            _apiClockOut = data.ClockOutTime;

            if (data.ClockInTime is not null && data.ClockOutTime is null)
            {
                IsClockedIn = true;
                In = LastClockInTime = TimeOnly.FromTimeSpan(data.ClockInTime.Value);

                var remaining = CooldownSeconds - (int)(DateTime.Now - DateTime.Today.Add(In.ToTimeSpan())).TotalSeconds;
                if (remaining > 0)
                    _ = RunCooldownAsync(remaining);
                else
                    DisableClockOut = false;
            }
        }
        else if (data.ClockInTime is not null && data.ClockOutTime is null && data.Date.Date < DateTime.Today)
        {
            IsClockInOut = true;
        }
    }

    private async Task PersistToStorage()
    {
        if (!_jsReady) return;
        try
        {
            await JS.InvokeVoidAsync("clockState.save", new
            {
                date = DateTime.Today.ToString(DateFmt),
                firstClockIn = FirstClockInDisplay,
                lastClockOut = LastClockOutDisplay,
                lastClockIn = LastClockInTime.ToString(ParseFmt),
                isClockedIn = IsClockedIn
            });
        }
        catch { }
    }

    private async Task RestoreFromStorage()
    {
        try
        {
            var state = await JS.InvokeAsync<ClockStateDto?>("clockState.load");
            var today = DateTime.Today.ToString(DateFmt);

            if (state?.Date == today)
            {
                FirstClockInDisplay ??= state.FirstClockIn;
                LastClockOutDisplay ??= state.LastClockOut;

                if (!string.IsNullOrEmpty(state.LastClockIn) && TimeOnly.TryParse(state.LastClockIn, out var t))
                    In = LastClockInTime = t;
            }
            else
            {
                await JS.InvokeVoidAsync("clockState.clear");
            }

            SeedFromApi();
            await PersistToStorage();
        }
        catch { }
    }

    private void SeedFromApi()
    {
        if (string.IsNullOrEmpty(FirstClockInDisplay) && _apiClockIn.HasValue)
            FirstClockInDisplay = Fmt(_apiClockIn.Value);

        if (string.IsNullOrEmpty(LastClockOutDisplay) && _apiClockOut.HasValue)
            LastClockOutDisplay = Fmt(_apiClockOut.Value);

        if (IsClockedIn && string.IsNullOrEmpty(FirstClockInDisplay))
            FirstClockInDisplay = LastClockInTime.ToString(DisplayFmt);
    }

    private static string Fmt(TimeSpan ts) => TimeOnly.FromTimeSpan(ts).ToString("hh:mm tt");

    private async Task ClockInAsync()
    {
        PendingClockIn = true;
        DisableClockIn = true;
        await PrepareAndOpenForm();
    }

    private async Task ClockOutAsync()
    {
        if (DisableClockOut) return;
        PendingClockIn = false;
        await PrepareAndOpenForm();
    }

    private void CloseForm()
    {
        ShowDynamicForm = false;
        if (PendingClockIn == true) DisableClockIn = false;
    }

    private async Task SubmitClockInOutAsync()
    {
        if (CurrentLatitude is null || CurrentLongitude is null)
        {
            await Toast("Location is required");
            return;
        }

        ShowDynamicForm = false;
        var isIn = PendingClockIn == true;

        try
        {
            await Loading(true, isIn ? "Clocking in…" : "Clocking out…");

            var empId = GetEmployeeId();
            if (empId == 0) return;

            var device = await JS.InvokeAsync<string>("deviceHelper.getDeviceType");

            if (isIn)
                await DoClockIn(empId, device);
            else
                await DoClockOut(empId, device);

            CurrentLatitude = CurrentLongitude = null;
        }
        finally
        {
            await Loading(false);
        }
    }

    private async Task DoClockIn(int empId, string device)
    {
        In = LastClockInTime = TimeOnly.FromDateTime(DateTime.Now);
        IsClockedIn = true;
        FirstClockInDisplay ??= In.ToString(DisplayFmt);

        var res = await ClockService.CreateAttendanceAsync(
            MakeVm(empId, device, clockIn: In.ToTimeSpan()));

        if (!res.IsSuccess)
        {
            IsClockedIn = false;
            DisableClockIn = false;
            await Toast(res.Message ?? "Clock-In failed");
            return;
        }

        AccumulatedHours = new TimeOnly(0, 0);
        _ = RunCooldownAsync(CooldownSeconds);
        await PersistToStorage();
        await Toast($"Clocked in at {In.ToString(DisplayFmt)}");
    }

    private async Task DoClockOut(int empId, string device)
    {
        Out = TimeOnly.FromDateTime(DateTime.Now);
        IsClockedIn = false;
        DisableClockIn = false;
        IsClockInOut = false;
        LastClockOutDisplay = Out.ToString(DisplayFmt);

        AccumulatedHours = AccumulatedHours.Add(Out.ToTimeSpan() - In.ToTimeSpan());

        var res = await ClockService.CreateAttendanceAsync(
            MakeVm(empId, device, clockOut: Out.ToTimeSpan(), hours: AccumulatedHours.ToTimeSpan()));

        if (!res.IsSuccess)
        {
            await Toast(res.Message ?? "Clock-Out failed");
            return;
        }

        await PersistToStorage();
        await Toast($"Clocked out at {Out.ToString(DisplayFmt)}");
    }

    private AttendanceViewModel MakeVm(
        int empId, string device,
        TimeSpan? clockIn = null, TimeSpan? clockOut = null,
        TimeSpan? hours = null) => new()
        {
            EmployeeId = empId,
            Date = DateTime.Today,
            ClockInTime = clockIn,
            ClockOutTime = clockOut,
            StatusId = AttendanceStatus.Present,
            Notes = attendanceViewModel.Notes,
            WorkingHours = hours ?? TimeSpan.Zero,
            Latitude = CurrentLatitude,
            Longitude = CurrentLongitude,
            Device = device
        };

    private void StartSessionTimer()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            try
            {
                while (await timer.WaitForNextTickAsync(token))
                {
                    if (!IsClockedIn) continue;
                    var e = DateTime.Now.TimeOfDay - LastClockInTime.ToTimeSpan();
                    SessionDuration = (e < TimeSpan.Zero ? TimeSpan.Zero : e).ToString(@"hh\:mm\:ss");
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    private async Task RunCooldownAsync(int seconds)
    {
        _cooldownCts?.Cancel();
        _cooldownCts = new CancellationTokenSource();

        DisableClockOut = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(seconds), _cooldownCts.Token);
            DisableClockOut = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    private async Task<bool> PrepareAndOpenForm()
    {
        try
        {
            await Loading(true, "Getting location…");
            var loc = await ClockService.GetCurrentLocationAsync();

            if (loc is null)
            {
                DisableClockIn = false;
                DisableClockOut = false;
                await Toast("Location permission is required");
                return false;
            }

            CurrentLatitude = loc.Value.Latitude;
            CurrentLongitude = loc.Value.Longitude;

            attendanceViewModel = new AttendanceViewModel();
            ShowDynamicForm = true;
            return true;
        }
        finally
        {
            await Loading(false);
        }
    }

    private async Task Toast(string msg)
    {
        ToastMessage = msg;
        ShowToast = true;
        await InvokeAsync(StateHasChanged);
        try { await Task.Delay(ToastMs); } catch (OperationCanceledException) { }
        ShowToast = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task Loading(bool show, string msg = "")
    {
        IsLoading = show;
        LoaderMessage = show ? msg : "";
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cooldownCts?.Cancel();
        _cooldownCts?.Dispose();
    }

    private sealed class ClockStateDto
    {
        [JsonPropertyName("date")] public string? Date { get; set; }
        [JsonPropertyName("firstClockIn")] public string? FirstClockIn { get; set; }
        [JsonPropertyName("lastClockOut")] public string? LastClockOut { get; set; }
        [JsonPropertyName("lastClockIn")] public string? LastClockIn { get; set; }
        [JsonPropertyName("isClockedIn")] public bool IsClockedIn { get; set; }
    }
}