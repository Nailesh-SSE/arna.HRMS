@using arna.HRMS.Components.Loader
@using arna.HRMS.Components.Pages.Attendance
@using arna.HRMS.Components.lib.components.ui.Forms
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels.Attendance
@using arna.HRMS.Services
@using arna.HRMS.Services.Auth

@implements IDisposable
@inject IAttendanceService ClockService
@inherits AuthenticatedLayoutBase
@inject IJSRuntime JS

<Loader Visible="@IsLoading" Message="@LoaderMessage" />

<div class="clock-container d-flex align-items-center gap-2 flex-wrap">
    @if (IsEmployee())
    {
        @* ── First Clock-In pill ── *@
        @if (!string.IsNullOrEmpty(FirstClockInDisplay))
        {
            <span class="clock-info-pill clock-info-pill--in" title="First clock-in today">
                <small class="clock-info-label text-success">ClockIn</small>
                <small class="clock-info-time">@FirstClockInDisplay</small>
            </span>
        }

        @* ── Last Activity pill ── *@
        @if (!string.IsNullOrEmpty(LastActivityDisplay))
        {
            <span class="clock-info-pill clock-info-pill--out" title="Last activity today">
                <small class="clock-info-label text-danger">ClockOut</small>
                <small class="clock-info-time">@LastActivityDisplay</small>
            </span>
        }

        @if (IsClockedIn)
        {
            @* ── Session timer ── *@
            <span class="clock-session-pill" title="Current session duration">
                <i class="bi bi-stopwatch clock-stopwatch-icon text-primary"></i>
                <small class="clock-session-time">@SessionDuration</small>
            </span>

            @* ── Clock-Out button with wrapper ── *@
            <span class="clock-btn-wrapper"
                  @onmouseenter="OnBtnMouseEnter"
                  @onmouseleave="OnBtnMouseLeave"
                  @onclick="HandleWrapperClick">

                <AppButton ButtonClass="btn btn-outline-danger btn-sm rounded-pill clock-action-btn"
                           Disabled="@CooldownActive"
                           OnClick="ClockOutAsync">
                    <i class="bi bi-stop-circle"></i>
                    <span class="ms-1">ClockOut</span>
                </AppButton>

                @if (ShowHoverTip)
                {
                    <div class="clock-hover-tip @HoverTipClass">
                        <i class="bi @HoverTipIcon"></i>
                        <span>@HoverTipText</span>
                    </div>
                }
            </span>
        }
        else
        {
            @* ── Clock-In button with wrapper ── *@
            <span class="clock-btn-wrapper"
                  @onmouseenter="OnBtnMouseEnter"
                  @onmouseleave="OnBtnMouseLeave"
                  @onclick="HandleWrapperClick">

                <AppButton ButtonClass="btn btn-success btn-sm rounded-pill clock-action-btn"
                           Disabled="@CooldownActive"
                           OnClick="ClockInAsync">
                    <i class="bi bi-play-circle"></i>
                    <span class="ms-1">ClockIn</span>
                </AppButton>

                @if (ShowHoverTip)
                {
                    <div class="clock-hover-tip @HoverTipClass">
                        <i class="bi @HoverTipIcon"></i>
                        <span>@HoverTipText</span>
                    </div>
                }
            </span>
        }
    }
</div>

@* ── Modal form ── *@
@if (ShowDynamicForm)
{
    <div class="clock-modal-overlay position-fixed top-0 start-0 w-100 h-100
                        d-flex align-items-center justify-content-center">
        <div class="clock-modal-card bg-white rounded-3 shadow-lg mx-3 p-4">
            <ClockInAndOutMessage Model="attendanceViewModel"
                                  OnSubmit="SubmitAsync"
                                  OnCancel="CloseForm" />
        </div>
    </div>
}

@* ── Toast notification ── *@
@if (ShowToast)
{
    <div class="clock-toast-wrapper position-fixed bottom-0 end-0 p-3">
        <div class="toast show border-0 shadow-lg rounded-3 bg-white @(IsToastWarning ? "clock-toast--warning" : "clock-toast--success")"
             role="alert">
            <div class="toast-body d-flex align-items-center gap-2 py-3 px-3">
                @if (IsToastWarning)
                {
                    <i class="bi bi-exclamation-triangle-fill text-warning fs-5"></i>
                }
                else
                {
                    <i class="bi bi-check-circle-fill text-success fs-5"></i>
                }
                <span>@ToastMessage</span>
            </div>
        </div>
    </div>
}

@code {
    // ───────── state ─────────
    private AttendanceViewModel attendanceViewModel = new();

    private bool IsClockedIn;
    private bool CooldownActive;
    private bool ShowDynamicForm, ShowToast, IsLoading;
    private bool ShowHoverTip, IsToastWarning;
    private bool? PendingClockIn;

    // ★ NEW: prevents double-loading & ensures data loads on reload
    private bool _dataLoaded;

    private int CooldownRemaining;
    private TimeOnly LastClockInTime;
    private string? FirstClockInDisplay, LastActivityDisplay;
    private string SessionDuration = "00:00:00";
    private string ToastMessage = "", LoaderMessage = "";
    private double? CurrentLatitude, CurrentLongitude;

    private CancellationTokenSource? _timerCts, _cooldownCts;
    private const int CooldownSec = 60;
    private const string TimeFmt = "hh:mm tt";

    // ───────── computed tooltip properties ─────────
    private string HoverTipClass => CooldownActive
        ? "clock-hover-tip--warn"
        : (IsClockedIn ? "clock-hover-tip--out" : "clock-hover-tip--in");

    private string HoverTipIcon => CooldownActive
        ? "bi-hourglass-split"
        : (IsClockedIn ? "bi-stop-circle" : "bi-play-circle");

    private string HoverTipText => CooldownActive
        ? $"Please wait {CooldownRemaining}s to {(IsClockedIn ? "Clock Out" : "Clock In")}"
        : (IsClockedIn ? "Click to Clock Out" : "Click to Clock In");

    // ───────── lifecycle ─────────

    // ★ FIX: Try loading in OnInitializedAsync first
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await TryLoadDataAsync();
        StartTimer();
    }

    // ★ FIX: If auth wasn't ready during OnInitializedAsync,
    //         retry here — auth IS available after first render
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_dataLoaded)
        {
            await TryLoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    // ★ FIX: Central method — only loads once, guards against empId == 0
    private async Task TryLoadDataAsync()
    {
        if (_dataLoaded) return;

        try
        {
            var id = GetEmployeeId();
            if (id <= 0) return;

            await LoadStatusAsync(id);
            _dataLoaded = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Clock] LoadStatus error: {ex.Message}");
        }
    }

    // ───────── load today's status ─────────
    private async Task LoadStatusAsync(int empId)
    {
        var firstTask = ClockService.GetTodayClockinEntryAsync(empId);
        var lastTask = ClockService.GetTodayLastEntryAsync(empId);
        var statusTask = ClockService.GetClockStatusAsync(empId);
        await Task.WhenAll(firstTask, lastTask, statusTask);

        var first = firstTask.Result;
        var last = lastTask.Result;
        var status = statusTask.Result;

        // ★ FIX: Set first clock-in display
        if (first.IsSuccess && first.Data?.ClockInTime is not null)
        {
            FirstClockInDisplay = Fmt(first.Data.ClockInTime.Value);
        }

        TimeSpan? activeClockIn = null;

        if (status.IsSuccess && status.Data is { ClockInTime: not null, ClockOutTime: null })
            activeClockIn = status.Data.ClockInTime.Value;
        else if (last.IsSuccess && last.Data is { ClockInTime: not null, ClockOutTime: null })
            activeClockIn = last.Data.ClockInTime.Value;

        if (activeClockIn.HasValue)
        {
            IsClockedIn = true;
            LastClockInTime = TimeOnly.FromTimeSpan(activeClockIn.Value);

            var remaining = CooldownSec
                - (int)(DateTime.Now - DateTime.Today.Add(activeClockIn.Value)).TotalSeconds;
            if (remaining > 0) _ = CooldownAsync(remaining);
        }
        else if (last.IsSuccess && last.Data?.ClockOutTime is not null)
        {
            var remaining = CooldownSec
                - (int)(DateTime.Now - DateTime.Today.Add(last.Data.ClockOutTime.Value)).TotalSeconds;
            if (remaining > 0) _ = CooldownAsync(remaining);
        }

        // ★ FIX: Set last activity display
        if (last.IsSuccess && last.Data is not null)
        {
            if (last.Data.ClockOutTime is not null)
            {
                LastActivityDisplay = Fmt(last.Data.ClockOutTime.Value);
            }
            else if (last.Data.ClockInTime is not null
                     && last.Data.ClockInTime != first.Data?.ClockInTime)
            {
                LastActivityDisplay = Fmt(last.Data.ClockInTime.Value);
            }
        }
    }

    // ───────── hover handlers ─────────
    private void OnBtnMouseEnter() => ShowHoverTip = true;
    private void OnBtnMouseLeave() => ShowHoverTip = false;

    // ───────── wrapper click (fires when button is disabled) ─────────
    private async Task HandleWrapperClick()
    {
        if (!CooldownActive) return;

        var action = IsClockedIn ? "Clock Out" : "Clock In";
        await ShowMsg(
            $"Please wait {CooldownRemaining} seconds before you can {action}.",
            warning: true);
    }

    // ───────── action entry-points ─────────
    private async Task ClockInAsync()
    {
        if (CooldownActive || ShowDynamicForm || IsLoading) return;
        PendingClockIn = true;
        await OpenForm();
    }

    private async Task ClockOutAsync()
    {
        if (CooldownActive || ShowDynamicForm || IsLoading) return;
        PendingClockIn = false;
        await OpenForm();
    }

    private void CloseForm() => ShowDynamicForm = false;

    // ───────── form submit ─────────
    private async Task SubmitAsync()
    {
        if (CurrentLatitude is null || CurrentLongitude is null)
        {
            await ShowMsg("Location is required.", warning: true);
            return;
        }

        ShowDynamicForm = false;
        var isIn = PendingClockIn == true;

        try
        {
            await SetLoading(true, isIn ? "Clocking in…" : "Clocking out…");

            var empId = GetEmployeeId();
            if (empId == 0) return;

            var device = await JS.InvokeAsync<string>("deviceHelper.getDeviceType");
            var now = TimeOnly.FromDateTime(DateTime.Now);

            if (isIn) await ProcessClockIn(empId, device, now);
            else await ProcessClockOut(empId, device, now);

            CurrentLatitude = CurrentLongitude = null;
        }
        finally { await SetLoading(false); }
    }

    private async Task ProcessClockIn(int empId, string device, TimeOnly now)
    {
        var res = await ClockService.CreateAttendanceAsync(
                      BuildVm(empId, device, clockIn: now.ToTimeSpan()));

        if (!res.IsSuccess)
        {
            await ShowMsg(res.Message ?? "Clock-In failed.", warning: true);
            return;
        }

        LastClockInTime = now;
        IsClockedIn = true;
        SessionDuration = "00:00:00";

        if (string.IsNullOrEmpty(FirstClockInDisplay))
            FirstClockInDisplay = now.ToString(TimeFmt);
        else
            LastActivityDisplay = now.ToString(TimeFmt);

        _ = CooldownAsync(CooldownSec);
        await ShowMsg($"Clocked in at {now.ToString(TimeFmt)}");
    }

    private async Task ProcessClockOut(int empId, string device, TimeOnly now)
    {
        var hours = now.ToTimeSpan() - LastClockInTime.ToTimeSpan();
        if (hours < TimeSpan.Zero) hours = TimeSpan.Zero;

        var res = await ClockService.CreateAttendanceAsync(
                      BuildVm(empId, device, clockOut: now.ToTimeSpan(), hours: hours));

        if (!res.IsSuccess)
        {
            await ShowMsg(res.Message ?? "Clock-Out failed.", warning: true);
            return;
        }

        IsClockedIn = false;
        SessionDuration = "00:00:00";
        LastActivityDisplay = now.ToString(TimeFmt);

        _ = CooldownAsync(CooldownSec);
        await ShowMsg($"Clocked out at {now.ToString(TimeFmt)}");
    }

    // ───────── build view-model ─────────
    private AttendanceViewModel BuildVm(int empId, string device,
        TimeSpan? clockIn = null, TimeSpan? clockOut = null, TimeSpan? hours = null) => new()
        {
            EmployeeId = empId,
            Date = DateTime.Today,
            ClockInTime = clockIn,
            ClockOutTime = clockOut,
            StatusId = AttendanceStatus.Present,
            Notes = attendanceViewModel.Notes,
            WorkingHours = hours ?? TimeSpan.Zero,
            Latitude = CurrentLatitude,
            Longitude = CurrentLongitude,
            Device = device
        };

    private static string Fmt(TimeSpan ts) =>
        TimeOnly.FromTimeSpan(ts).ToString("hh:mm tt");

    // ───────── session timer (1-s tick) ─────────
    private void StartTimer()
    {
        _timerCts?.Cancel();
        _timerCts = new();
        var token = _timerCts.Token;

        _ = Task.Run(async () =>
        {
            using var tick = new PeriodicTimer(TimeSpan.FromSeconds(1));
            try
            {
                while (await tick.WaitForNextTickAsync(token))
                {
                    if (!IsClockedIn) continue;
                    var elapsed = DateTime.Now.TimeOfDay - LastClockInTime.ToTimeSpan();
                    if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;
                    SessionDuration = elapsed.ToString(@"hh\:mm\:ss");
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    // ───────── cooldown (blocks BOTH buttons for N seconds) ─────────
    private async Task CooldownAsync(int seconds)
    {
        _cooldownCts?.Cancel();
        _cooldownCts = new();
        var token = _cooldownCts.Token;

        CooldownActive = true;
        CooldownRemaining = seconds;
        await InvokeAsync(StateHasChanged);

        try
        {
            while (CooldownRemaining > 0)
            {
                await Task.Delay(1000, token);
                CooldownRemaining--;
                await InvokeAsync(StateHasChanged);
            }

            CooldownActive = false;
            ShowHoverTip = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    // ───────── open form (location) ─────────
    private async Task OpenForm()
    {
        try
        {
            await SetLoading(true, "Getting location…");
            var loc = await ClockService.GetCurrentLocationAsync();

            if (loc is null)
            {
                await ShowMsg("Location permission is required.", warning: true);
                return;
            }

            CurrentLatitude = loc.Value.Latitude;
            CurrentLongitude = loc.Value.Longitude;
            attendanceViewModel = new();
            ShowDynamicForm = true;
        }
        finally { await SetLoading(false); }
    }

    // ───────── toast (success / warning) ─────────
    private async Task ShowMsg(string msg, bool warning = false)
    {
        ToastMessage = msg;
        IsToastWarning = warning;
        ShowToast = true;
        await InvokeAsync(StateHasChanged);
        try { await Task.Delay(3000); } catch { }
        ShowToast = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetLoading(bool on, string msg = "")
    {
        IsLoading = on;
        LoaderMessage = on ? msg : "";
        await InvokeAsync(StateHasChanged);
    }

    // ───────── cleanup ─────────
    public void Dispose()
    {
        _timerCts?.Cancel(); _timerCts?.Dispose();
        _cooldownCts?.Cancel(); _cooldownCts?.Dispose();
    }
}