@using arna.HRMS.Components.Loader
@using arna.HRMS.Components.Pages.Attendance
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels.Attendance
@using arna.HRMS.Services
@using arna.HRMS.Services.Auth

@implements IDisposable
@inject IAttendanceService ClockService
@inject IJSRuntime JS
@inherits AuthenticatedLayoutBase

<Loader Visible="@IsLoading" Message="@LoaderMessage" />

@if (IsEmployee())
{
    <div class="container-fluid px-2 px-md-3 py-2">
        <div class="row g-2 align-items-stretch">

            @* ── First In ── *@
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body d-flex align-items-center gap-2 p-2 p-md-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center
                                            bg-success bg-opacity-10 text-success flex-shrink-0 cw-icon-box">
                            <i class="bi bi-box-arrow-in-right"></i>
                        </div>
                        <div class="min-w-0">
                            <div class="text-muted cw-label">First In</div>
                            <div class="fw-bold text-truncate cw-value">
                                @(string.IsNullOrEmpty(FirstClockInDisplay)
                                                            ? "--:-- --" : FirstClockInDisplay)
                                                                                           </div>
                                                                                       </div>
                                                                                   </div>
                                                                               </div>
                                                                           </div>

            @* ── Last Out ── *@
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body d-flex align-items-center gap-2 p-2 p-md-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center
                                            bg-danger bg-opacity-10 text-danger flex-shrink-0 cw-icon-box">
                            <i class="bi bi-box-arrow-right"></i>
                        </div>
                        <div class="min-w-0">
                            <div class="text-muted cw-label">Last Out</div>
                            <div class="fw-bold text-truncate cw-value">
                                @(string.IsNullOrEmpty(LastActivityDisplay)
                                                            ? "--:-- --" : LastActivityDisplay)
                        </div>
                    </div>
                </div>
            </div>
        </div>

            @* ── Clock Action + Timer ── *@
            <div class="col-12 col-md-6">
                <div class="card border-0 shadow-sm rounded-3 h-100
                                    @(MissedClockOutYesterday ? "cw-missed-border" : "")">
                    <div class="card-body d-flex align-items-center justify-content-between
                                        gap-2 p-2 p-md-3">

                        @* ── ACTION BUTTON ── *@
                        <button class="btn d-flex align-items-center justify-content-center
                       gap-1 rounded-3 flex-shrink-0 cw-action-btn
                       @ButtonClass"
                                @onclick="HandleClick"
                                disabled="@(CooldownActive || ShowDynamicForm)">

                        @if (MissedClockOutYesterday && !IsClockedIn)
                            {
                                <i class="bi bi-exclamation-triangle-fill cw-icon"></i>
                            }
                            else if (IsClockedIn)
                            {
                                <i class="bi bi-stop-fill cw-icon"></i>
                            }
                            else
                            {
                                <i class="bi bi-play-fill cw-icon"></i>
                            }

                        </button>

                        @* ── STATUS BADGE (all devices) ── *@
                        <div class="min-w-0">
                            @if (CooldownActive)
                            {
                                <span class="badge bg-warning bg-opacity-10 text-warning
                                                             rounded-pill px-2 py-1 cw-label">
                                    <i class="bi bi-hourglass-split me-1"></i>@(CooldownRemaining)s
                                </span>
                            }
                            else if (MissedClockOutYesterday && !IsClockedIn)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger
                                                             rounded-pill px-2 py-1 cw-label cw-missed-badge">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>Missed
                                </span>
                            }
                            else
                            {
                                <span class="text-muted cw-label">
                                    @(IsClockedIn ? "Working" : "Ready")
                                </span>
                            }
                        </div>

                        @* ── TIMER ── *@
                        <div class="d-flex align-items-center gap-1 gap-md-2 ms-auto">
                            <i class="bi bi-stopwatch text-primary cw-label"></i>
                            <span class="fw-bold text-nowrap cw-timer
                                                 @(IsClockedIn ? "text-primary" : "text-muted")">
                                @SessionDuration
                            </span>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        @if (MissedClockOutYesterday)
        {
            <div class="alert alert-danger border-0 shadow-sm rounded-3
                                        py-2 px-3 mt-2 mb-0 d-flex align-items-center gap-2 cw-missed-alert">
                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                <div>
                    <strong class="small">Missed Clock-Out!</strong>
                    <div class="cw-label text-danger-emphasis">
                        You forgot to clock out yesterday. Please clock in to start a new session.
                    </div>
                </div>
            </div>
        }
    </div>

    @* ═══════ MODAL ═══════ *@
    @if (ShowDynamicForm)
    {
        <div class="position-fixed top-0 start-0 w-100 h-100
                                    d-flex align-items-center justify-content-center p-2 p-md-3"
             style="z-index:1050; background:rgba(0,0,0,.5); backdrop-filter:blur(3px);"
             @onclick="CloseForm">

            <div class="bg-white rounded-4 shadow-lg w-100 overflow-hidden"
                 style="max-width:460px;"
                 @onclick:stopPropagation="true">

                @* Modal Header *@
                <div class="d-flex align-items-center justify-content-between px-3 py-2 text-white
                                            @ModalHeaderClass">
                    <div class="d-flex align-items-center gap-2 fw-semibold small">
                        <i class="bi @(PendingClockIn == true
                                                                                             ? "bi-play-circle" : "bi-stop-circle")"></i>
                @(PendingClockIn == true ? "Clock In" : "Clock Out")

                @if (MissedClockOutYesterday && PendingClockIn == true)
                        {
                            <span class="badge bg-white text-danger rounded-pill px-2 py-1"
                                  style="font-size:0.6rem;">
                                Missed yesterday
                            </span>
                        }
                    </div>
                    <button class="btn btn-sm text-white p-0 border-0"
                            @onclick="CloseForm">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="p-3 p-md-4">
                    <ClockInAndOutMessage Model="attendanceViewModel"
                                          OnSubmit="SubmitAsync"
                                          OnCancel="CloseForm" />
                </div>
            </div>
        </div>
    }

    @* ═══════ TOAST ═══════ *@
    @if (ShowToast)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1090;">
            <div class="toast show border-0 shadow-lg rounded-3 cw-toast
                                        @(IsToastWarning ? "bg-warning text-dark" : "bg-success text-white")"
                 role="alert">
                <div class="toast-body d-flex align-items-center gap-2 py-2 px-3">
                    <i class="bi @(IsToastWarning
                                                                                  ? "bi-exclamation-triangle-fill"
                                                                                  : "bi-check-circle-fill")"></i>
            <span class="small fw-medium">@ToastMessage</span>
            <button type="button"
                    class="btn-close btn-close-white ms-auto p-0"
                    style="font-size:0.6rem;"
                    @onclick="() => ShowToast = false"></button>
        </div>
    </div>
</div>
    }
}

@code {
    /* ════════════════  STATE  ════════════════ */

    private AttendanceViewModel attendanceViewModel = new();

    private bool IsClockedIn;
    private bool CooldownActive;
    private bool ShowDynamicForm;
    private bool ShowToast;
    private bool IsLoading;
    private bool IsToastWarning;
    private bool MissedClockOutYesterday;
    private bool? PendingClockIn;

    private int CooldownRemaining;
    private DateTime? LastClockInDateTime;

    private string? FirstClockInDisplay;
    private string? LastActivityDisplay;
    private string SessionDuration = "00:00:00";
    private string ToastMessage = "";
    private string LoaderMessage = "";
    private double? CurrentLatitude;
    private double? CurrentLongitude;

    private CancellationTokenSource? _timerCts, _cooldownCts, _refreshCts;

    private const int CooldownSec = 60;
    private const string TimeFmt = "hh:mm tt";
    private const int RefreshIntervalSec = 5;

    /* ════════════════  COMPUTED PROPERTIES  ════════════════ */

    /// Button color: RED if missed yesterday, DANGER if clocked in, PRIMARY if idle
    private string ButtonClass
    {
        get
        {
            if (MissedClockOutYesterday && !IsClockedIn)
                return "btn-danger cw-btn-missed";    // RED for missed
            if (IsClockedIn)
                return "btn-danger";                  // RED for clock-out
            return "btn-primary";                     // BLUE for clock-in
        }
    }

    private string ModalHeaderClass
    {
        get
        {
            if (MissedClockOutYesterday && PendingClockIn == true)
                return "bg-danger bg-gradient";
            return PendingClockIn == true
                ? "bg-primary bg-gradient"
                : "bg-danger bg-gradient";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await TryLoadDataAsync();
        StartSessionTimer();
        StartRefreshTimer();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await TryLoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task TryLoadDataAsync()
    {
        try
        {
            var id = GetEmployeeId();
            if (id <= 0) return;

            await LoadStatusAsync(id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Clock] LoadStatus error: {ex.Message}");
        }
    }

    private async Task LoadStatusAsync(int empId)
    {
        try
        {
            MissedClockOutYesterday = false;

            var todayResult = await ClockService.GetTodayClockinEntryAsync(empId);
            var todayRecords = todayResult?.Data ?? new List<AttendanceViewModel>();

            if (todayRecords.Any())
            {
                // First clock-in
                var firstClock = todayRecords
                    .Where(x => x.ClockInTime != null)
                    .OrderBy(x => x.ClockInTime)
                    .FirstOrDefault();

                if (firstClock?.ClockInTime != null)
                    FirstClockInDisplay = Fmt(firstClock.ClockInTime.Value);

                // Last record
                var last = todayRecords
                    .OrderByDescending(x => x.CreatedOn)
                    .FirstOrDefault();

                if (last != null)
                {
                    if (last.ClockInTime != null && last.ClockOutTime == null)
                    {
                        IsClockedIn = true;
                        LastClockInDateTime = last.CreatedOn;
                    }
                    else if (last.ClockOutTime != null)
                    {
                        IsClockedIn = false;
                        LastActivityDisplay = Fmt(last.ClockOutTime.Value);
                    }
                    else
                    {
                        IsClockedIn = false;
                    }

                    // Resume cooldown
                    if (last.CreatedOn != default)
                    {
                        var remaining =
                            CooldownSec - (int)(DateTime.Now - last.CreatedOn).TotalSeconds;

                        if (remaining > 0)
                            _ = CooldownAsync(remaining);
                    }
                }

                return;
            }

            // ── No today records → check missed clock-out yesterday ──
            var lastResult = await ClockService.GetTodayLastEntryAsync(empId);

            if (lastResult?.Data is { } prev
                && prev.ClockInTime != null
                && prev.ClockOutTime == null
                && prev.Date.Date < DateTime.Today)
            {
                MissedClockOutYesterday = true;
                IsClockedIn = false;
            }
            else
            {
                IsClockedIn = false;
                MissedClockOutYesterday = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Clock] LoadStatus error: {ex.Message}");
        }
    }

    private async Task HandleClick()
    {
        if (CooldownActive || ShowDynamicForm || IsLoading) return;

        PendingClockIn = !IsClockedIn;
        await OpenFormWithLocation();
    }

    private void CloseForm()
    {
        ShowDynamicForm = false;
        StateHasChanged();
    }

    private async Task OpenFormWithLocation()
    {
        try
        {
            await SetLoading(true, "Getting location…");

            var loc = await ClockService.GetCurrentLocationAsync();

            if (loc is null)
            {
                await ShowMsg("Location permission is required.", warning: true);
                return;
            }

            CurrentLatitude = loc.Value.Latitude;
            CurrentLongitude = loc.Value.Longitude;
            attendanceViewModel = new();
            ShowDynamicForm = true;
        }
        catch (Exception ex)
        {
            await ShowMsg($"Location error: {ex.Message}", warning: true);
        }
        finally
        {
            await SetLoading(false);
        }
    }

    /* ════════════════  FORM SUBMIT  ════════════════ */

    private async Task SubmitAsync()
    {
        if (CurrentLatitude is null || CurrentLongitude is null)
        {
            await ShowMsg("Location is required.", warning: true);
            return;
        }

        ShowDynamicForm = false;
        var isIn = PendingClockIn == true;

        try
        {
            await SetLoading(true, isIn ? "Clocking in…" : "Clocking out…");

            var empId = GetEmployeeId();
            if (empId == 0)
            {
                await ShowMsg("Employee not found.", warning: true);
                return;
            }

            DeviceType device;
            try
            {
                var deviceStr = await JS.InvokeAsync<string>("deviceHelper.getDeviceType");
                if (!Enum.TryParse<DeviceType>(deviceStr, true, out device))
                    device = DeviceType.UnknownDevice;
            }
            catch
            {
                device = DeviceType.UnknownDevice;
            }

            var now = DateTime.Now;

            if (isIn)
                await ProcessClockIn(empId, device, now);
            else
                await ProcessClockOut(empId, device, now);

            // Force refresh after action
            await LoadStatusAsync(empId);

            CurrentLatitude = CurrentLongitude = null;
        }
        catch (Exception ex)
        {
            await ShowMsg($"Error: {ex.Message}", warning: true);
        }
        finally
        {
            await SetLoading(false);
        }
    }

    private async Task ProcessClockIn(int empId, DeviceType device, DateTime now)
    {
        var vm = BuildVm(empId, device, clockIn: now.TimeOfDay);
        var res = await ClockService.CreateAttendanceAsync(vm);

        if (!res.IsSuccess)
        {
            await ShowMsg(res.Message ?? "Clock-In failed.", warning: true);
            return;
        }

        IsClockedIn = true;
        LastClockInDateTime = now;
        SessionDuration = "00:00:00";
        MissedClockOutYesterday = false;

        if (string.IsNullOrEmpty(FirstClockInDisplay))
            FirstClockInDisplay = now.ToString(TimeFmt);

        _ = CooldownAsync(CooldownSec);
        await ShowMsg($"Clocked in at {now.ToString(TimeFmt)}");
    }

    private async Task ProcessClockOut(int empId, DeviceType device, DateTime now)
    {
        var hours = LastClockInDateTime != null
            ? now - LastClockInDateTime.Value
            : TimeSpan.Zero;

        if (hours < TimeSpan.Zero) hours = TimeSpan.Zero;

        var vm = BuildVm(empId, device, clockOut: now.TimeOfDay, hours: hours);
        var res = await ClockService.CreateAttendanceAsync(vm);

        if (!res.IsSuccess)
        {
            await ShowMsg(res.Message ?? "Clock-Out failed.", warning: true);
            return;
        }

        IsClockedIn = false;
        SessionDuration = "00:00:00";
        LastActivityDisplay = now.ToString(TimeFmt);

        _ = CooldownAsync(CooldownSec);
        await ShowMsg($"Clocked out at {now.ToString(TimeFmt)}");
    }

    /* ════════════════  BUILD VM  ════════════════ */

    private AttendanceViewModel BuildVm(
        int empId, DeviceType device,
        TimeSpan? clockIn = null,
        TimeSpan? clockOut = null,
        TimeSpan? hours = null) => new()
        {
            EmployeeId = empId,
            Date = DateTime.Today,
            ClockInTime = clockIn,
            ClockOutTime = clockOut,
            WorkingHours = hours,
            DeviceId = device,
            Latitude = CurrentLatitude,
            Longitude = CurrentLongitude,
            Notes = attendanceViewModel.Notes ?? string.Empty,
            StatusId = AttendanceStatus.Present
        };

    /* ════════════════  SESSION TIMER  ════════════════ */

    private void StartSessionTimer()
    {
        _timerCts?.Cancel();
        _timerCts = new CancellationTokenSource();
        var token = _timerCts.Token;

        _ = Task.Run(async () =>
        {
            using var tick = new PeriodicTimer(TimeSpan.FromSeconds(1));

            try
            {
                while (await tick.WaitForNextTickAsync(token))
                {
                    if (!IsClockedIn || LastClockInDateTime is null) continue;

                    var elapsed = DateTime.Now - LastClockInDateTime.Value;
                    if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;

                    SessionDuration = elapsed.ToString(@"hh\:mm\:ss");
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    /* ════════════════  REFRESH TIMER  ════════════════ */

    private void StartRefreshTimer()
    {
        _refreshCts?.Cancel();
        _refreshCts = new CancellationTokenSource();
        var token = _refreshCts.Token;

        _ = Task.Run(async () =>
        {
            using var tick = new PeriodicTimer(TimeSpan.FromSeconds(RefreshIntervalSec));

            try
            {
                while (await tick.WaitForNextTickAsync(token))
                {
                    try
                    {
                        var empId = GetEmployeeId();
                        if (empId > 0)
                            await InvokeAsync(async () => await LoadStatusAsync(empId));
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"[Clock] Refresh error: {ex.Message}");
                    }
                }
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    /* ════════════════  COOLDOWN  ════════════════ */

    private async Task CooldownAsync(int seconds)
    {
        _cooldownCts?.Cancel();
        _cooldownCts = new CancellationTokenSource();
        var token = _cooldownCts.Token;

        CooldownActive = true;
        CooldownRemaining = seconds;

        try
        {
            await InvokeAsync(StateHasChanged);

            while (CooldownRemaining > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token);
                CooldownRemaining--;
                await InvokeAsync(StateHasChanged);
            }

            CooldownActive = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    /* ════════════════  HELPERS  ════════════════ */

    private static string Fmt(TimeSpan ts)
        => TimeOnly.FromTimeSpan(ts).ToString("hh:mm tt");

    private async Task ShowMsg(string msg, bool warning = false)
    {
        ToastMessage = msg;
        IsToastWarning = warning;
        ShowToast = true;

        await InvokeAsync(StateHasChanged);

        try { await Task.Delay(4000); } catch { }

        ShowToast = false;

        try { await InvokeAsync(StateHasChanged); } catch { }
    }

    private async Task SetLoading(bool on, string msg = "")
    {
        IsLoading = on;
        LoaderMessage = on ? msg : "";
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _timerCts?.Cancel(); _timerCts?.Dispose();
        _cooldownCts?.Cancel(); _cooldownCts?.Dispose();
        _refreshCts?.Cancel(); _refreshCts?.Dispose();
    }
}