@page "/leave-report"

@using arna.HRMS.Components.Pages.Report.Admin
@using arna.HRMS.Components.lib.components.ui.Forms
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels
@using arna.HRMS.Services.Report
@using arna.HRMS.Components.Loader
@using arna.HRMS.Models.Common.Table
@using arna.HRMS.Models.ViewModels.Attendance
@using arna.HRMS.Services
@using arna.HRMS.Services.Common

@inject IReportService ReportService

<h3>Leave Report</h3>

@if (isLoading && !showDetail)
{
    <Loader Visible="isLoading" Message="Loading employee reports…" />
}
else if (!showDetail)
{
<div class="emp-report-fade-in">
    <!-- ══════════ FILTER CARD ══════════ -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-3 p-md-4">
            <div class="row align-items-end g-3">

                <!-- From Date -->
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <label class="form-label small fw-semibold text-muted mb-1">
                        <i class="bi bi-calendar-event me-1"></i>From Date
                    </label>

                    <InputDate TValue="DateTime?"
                               Value="fromDate"
                               ValueChanged="@(async (DateTime? value) => await OnFromDateChanged(value))"
                               ValueExpression="() => fromDate"
                               class="form-control form-control-sm" />
                </div>

                <!-- To Date -->
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <label class="form-label small fw-semibold text-muted mb-1">
                        <i class="bi bi-calendar-event me-1"></i>To Date
                    </label>

                    <InputDate TValue="DateTime?"
                               Value="toDate"
                               ValueChanged="@(async (DateTime? value) => await OnToDateChanged(value))"
                               ValueExpression="() => toDate"
                               class="form-control form-control-sm" />
                </div>

                <!-- Reset -->
                <div class="col-auto">
                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3"
                            @onclick="ResetDates">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                    </button>
                </div>

                <!-- 🔍 Search (NEW) -->
                <div class="col-12 col-md-auto ms-md-auto">
                    <div class="position-relative">
                        <i class="bi bi-search position-absolute top-50 translate-middle-y text-muted"
                           style="left:12px;"></i>
                        <input type="text"
                               class="form-control form-control-sm rounded-pill ps-5"
                               placeholder="Search by name or number…"
                               style="min-width:240px;"
                               @bind="_searchText"
                               @bind:event="oninput" />

                        @if (!string.IsNullOrWhiteSpace(_searchText))
                        {
                            <button class="btn btn-link btn-sm position-absolute top-50 translate-middle-y border-0 p-0"
                                    style="right:10px;"
                                    @onclick="ClearSearch">
                                <i class="bi bi-x-lg text-muted"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════ TABLE CARD ══════════ -->
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-white border-bottom py-3 px-3 px-md-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <h6 class="fw-semibold mb-0">
                    <i class="bi bi-table text-primary me-2"></i>Employee Summary
                </h6>
                <span class="badge bg-light text-dark rounded-pill px-3 py-1 border">
                    <i class="bi bi-list-ul me-1"></i>@FilteredEmployees.Count employees
                </span>
            </div>
        </div>
        <div class="card-body p-0">
            @if (!FilteredEmployees.Any())
            {
                <div class="text-center py-5 px-3">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:72px; height:72px;">
                        <i class="bi bi-person-slash fs-2 text-muted opacity-50"></i>
                    </div>
                    <h6 class="fw-semibold text-muted mb-1">No Employees Found</h6>
                    <p class="text-muted small mb-3 mx-auto" style="max-width:360px;">
                        @if (!string.IsNullOrWhiteSpace(_searchText))
                        {
                            <span>No employees match "<strong>@_searchText</strong>"</span>
                        }
                        else
                        {
                            <span>
                                No attendance data from
                                <strong>@FormatDate(fromDate)</strong> to
                                <strong>@FormatDate(toDate)</strong>.
                            </span>
                        }
                    </p>
                    @if (!string.IsNullOrWhiteSpace(_searchText))
                    {
                        <button class="btn btn-sm btn-outline-primary rounded-pill px-4"
                                @onclick="ClearSearch">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Clear Search
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm"
                                @onclick="ResetDates">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset to Current Month
                        </button>
                    }
                </div>
            }
            else
            {
                <AppTable TItem="LeaveSummaryReportViewModel"
                          Items="FilteredEmployees"
                          Columns="TableSchemas.LeaveSummaryReport"
                          EnablePagination="true"
                          PageSize="10"
                          WrapperClass="emp-report-table">
                    <ActionTemplate Context="emp">
                        <AppButton ButtonClass="btn btn-sm btn-outline-primary rounded-pill px-3"
                                   OnClick="() => OpenDetail(emp)">
                            <i class="bi bi-eye me-1"></i>
                            <span class="d-none d-sm-inline">View</span>
                        </AppButton>
                    </ActionTemplate>
                </AppTable>
            }
        </div>
    </div>
</div>
}
else
{
    <!-- ═══════════════════════════════════════════
         FIX: Only pass dates when user manually
         changed them. Otherwise pass null so
         detail page defaults to month mode.
         ═══════════════════════════════════════════ -->
    <LeaveDetailsReportPage Employee="selectedEmployee!"
                      InitialFromDate="@(isCustomDateRange ? (DateTime?)fromDate : null)"
                      InitialToDate="@(isCustomDateRange ? (DateTime?)toDate : null)"
                      OnBackClicked="BackToList" />
}
@code {

    private List<LeaveSummaryReportViewModel> reportData = new();
    private List<EmployeeLeaveDetailsReportViewModel> detailsData = new();
    private int? year;
    private int? month;
    private int? departmentId;
    private DateTime? fromDate;
    private DateTime? toDate;
    private bool isCustomDateRange;
    private string _searchText = "";
    private bool showDetail;
    private bool isLoading;

    private EmployeeViewModel? selectedEmployee;

    protected override async Task OnInitializedAsync()
    {
        SetDefaultDates();
        await LoadReport(new ReportFilter
        {
            FromDate = fromDate,
            ToDate = toDate
        });
    }

    async Task ApplyFilter()
    {
        await LoadReport(new ReportFilter
        {
            Year = year,
            Month = month,
            DepartmentId = departmentId,
            FromDate = fromDate,
            ToDate = toDate
        });
    }

    private void SetDefaultDates()
    {
        var today = DateTime.Today;
        fromDate = new DateTime(today.Year, today.Month, 1);
        toDate = new DateTime(today.Year, today.Month,
                              DateTime.DaysInMonth(today.Year, today.Month));
        isCustomDateRange = false;
    }

    private static string FormatDate(DateTime? date)
        => date?.ToString("dd/MM/yy") ?? "";

    /* ───── Search ───── */
    private void ClearSearch() => _searchText = "";

    private bool MatchesSearch(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    private List<LeaveSummaryReportViewModel> FilteredEmployees =>
        string.IsNullOrWhiteSpace(_searchText)
            ? reportData
            : reportData.Where(e =>
                MatchesSearch(e.EmployeeName) ||
                MatchesSearch(e.EmployeeNumber)
            ).ToList();


    /* ───── Navigation ───── */
    private void OpenDetail(LeaveSummaryReportViewModel emp)
    {
        // Split EmployeeName into FirstName and LastName
        var nameParts = (emp.EmployeeName ?? "").Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);

        selectedEmployee = new EmployeeViewModel
        {
            Id = emp.EmployeeId,
            EmployeeNumber = emp.EmployeeNumber,
            FirstName = nameParts.Length > 0 ? nameParts[0] : "",
            LastName = nameParts.Length > 1 ? nameParts[1] : "",
        };
        showDetail = true;
    }

    private async Task ResetDates()
    {
        SetDefaultDates();
        _searchText = "";
        await ApplyFilter();
    }
    async Task LoadReport(ReportFilter filter)
    {
        try
        {

            isLoading = true;
            StateHasChanged();

            year = filter.Year ?? DateTime.Now.Year;
            month = filter.Month;
            departmentId = filter.DepartmentId;
            fromDate = filter.FromDate.HasValue
           ? filter.FromDate.Value.Date
           : fromDate;

            toDate = filter.ToDate.HasValue
                ? filter.ToDate.Value.Date
                : toDate;

            reportData = new List<LeaveSummaryReportViewModel>();
            await InvokeAsync(StateHasChanged);

            var result = await ReportService.GetEmployeeLeaveSummaryReportAsync(
                year,
                month,
                departmentId,
                fromDate,
                toDate
            );

            if (result.IsSuccess && result.Data != null)
            {
                reportData = result.Data.ToList();
            }
            else
            {
                reportData = new List<LeaveSummaryReportViewModel>();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            reportData = new();
            // await NotificationService.Error($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    async Task ViewDetails(int employeeId, string employeeNumber)
    {
        detailsData = new List<EmployeeLeaveDetailsReportViewModel>();
        await InvokeAsync(StateHasChanged);

        var result = await ReportService.GetEmployeeLeaveDetailsReportAsync(
            year,
            month,
            fromDate,
            toDate,
            employeeId,
            employeeNumber
        );
        if (result.IsSuccess && result.Data != null)
        {
            detailsData = result.Data.ToList();
        }
        else
        {
            detailsData = new List<EmployeeLeaveDetailsReportViewModel>();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnFromDateChanged(DateTime? value)
    {
        fromDate = value;

        if (fromDate > toDate)
            toDate = fromDate;

        await ApplyFilter();
    }

    private async Task OnToDateChanged(DateTime? value)
    {
        toDate = value;

        if (toDate < fromDate)
            fromDate = toDate;

        await ApplyFilter();
    }
    private void BackToList()
    {
        showDetail = false;
        selectedEmployee = null;
    }
}