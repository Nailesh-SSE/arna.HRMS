@using arna.HRMS.Components.Pages.Report.Component
@using arna.HRMS.Components.lib.components.ui.CommonComponent
@using arna.HRMS.Components.lib.components.ui.Model
@using arna.HRMS.Models.State.Attendance
@using arna.HRMS.Models.ViewModels
@using arna.HRMS.Services

@inject IJSRuntime JS
@inject AttendanceState State
@inject IEmployeeService EmployeeService

<div class="card border-0 shadow-sm rounded-3 mt-4">

    <!-- HEADER -->
    <div class="card-header bg-white border-bottom">
        <h5 class="mb-0">
            <i class="bi bi-bar-chart"></i> Employee Attendance Status
        </h5>
    </div>

    <div class="card-body">

        <!-- FILTER BAR -->
        <div class="row align-items-center g-2 mb-3">

            <!-- ICON -->
            <div class="col-auto">
                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
                    <i class="bi bi-funnel-fill me-1"></i> Filters
                </span>
            </div>

            <!-- CENTER FILTERS -->
            <div class="col d-flex justify-content-center">
                <div class="d-flex align-items-center gap-3">

                    <!-- YEAR MONTH -->
                    <div style="min-width:200px;">
                        <YearMonthPicker Year="Year"
                                         Month="Month"
                                         OnChange="OnDateChange" />
                    </div>

                    <!-- EMPLOYEE SEARCH -->
                    <div style="min-width:250px;">
                        <SearchEmployee Employees="EmployeeOptions"
                                        SelectedValue="@GetEmployeeValue()"
                                        OnChanged="OnEmployeeChange"
                                        OnNameChanged="OnEmployeeNameChanged" />
                    </div>

                </div>
            </div>

            <!-- CLEAR FILTER -->
            @if (HasActiveFilters)
            {
                <div class="col-auto">
                    <button class="btn btn-outline-secondary btn-sm rounded-pill px-3"
                            @onclick="ClearFilters">
                        <i class="bi bi-x-lg me-1"></i> Clear Filters
                    </button>
                </div>
            }

        </div>


        <!-- CHART -->
        <div style="height:500px; position:relative">

            @if (ReportData == null || ReportData.Count == 0)
            {
                <div style="height:500px;" class="d-flex justify-content-center align-items-center">

                    <div class="text-center text-muted">
                        <i class="bi bi-bar-chart-line" style="font-size:60px;"></i>
                        <p class="mt-3 fw-semibold fs-4">No attendance data available</p>
                    </div>

                </div>
            }

            <canvas id="statusChart"></canvas>

        </div>

    </div>
</div>


@code {

    /* PARAMETERS */

    [Parameter] public List<AttendanceReportViewModel> ReportData { get; set; } = new();
    [Parameter] public int? Year { get; set; }
    [Parameter] public int? Month { get; set; }
    [Parameter] public int? EmployeeId { get; set; }
    [Parameter] public EventCallback<AttendanceFilter> OnFilter { get; set; }


    /* EMPLOYEE DROPDOWN */

    private List<SelectOption> EmployeeOptions = new();
    private string? _selectedEmployeeName;
    private string? _selectedEmployeeNumber;


    /* FILTER STATE */

    private bool HasActiveFilters =>
        EmployeeId.HasValue || Year.HasValue || Month.HasValue;


    /* LIFECYCLE */

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }


    protected override async Task OnParametersSetAsync()
    {
        if (ReportData != null && ReportData.Count > 0)
        {
            await JS.InvokeVoidAsync("drawStatusBarChart", ReportData, Year, Month);
        }
        else
        {
            await JS.InvokeVoidAsync("destroyStatusChart");
        }
    }


    /* LOAD EMPLOYEES */

    private async Task LoadEmployees()
    {
        try
        {
            var result = await EmployeeService.GetEmployeesAsync();

            EmployeeOptions = result?.IsSuccess == true
                ? result.Data.Select(e => new SelectOption
                {
                    Value = e.Id.ToString(),
                    Text = $"{e.FullName} ({e.EmployeeNumber})"
                }).ToList()
                : new();
        }
        catch
        {
            EmployeeOptions = new();
        }
    }


    /* FILTER EVENTS */

    async Task OnDateChange((int year, int month) value)
    {
        Year = value.year;
        Month = value.month;
        await ApplyFilter();
    }


    async Task OnEmployeeChange(string? empId)
    {
        EmployeeId =
            !string.IsNullOrWhiteSpace(empId) && empId != "0"
                ? int.Parse(empId)
                : null;

        State.SelectedEmployeeId = EmployeeId;

        await ApplyFilter();
    }


    async Task OnEmployeeNameChanged(string? text)
    {
        _selectedEmployeeName = text;
    }


    async Task ClearFilters()
    {
        EmployeeId = null;
        State.SelectedEmployeeId = null;

        Year = DateTime.Now.Year;
        Month = DateTime.Now.Month;

        await ApplyFilter();
    }


    /* APPLY FILTER */

    async Task ApplyFilter()
    {
        var filter = new AttendanceFilter
        {
            Year = Year,
            Month = Month,
            EmployeeId = EmployeeId
        };

        await OnFilter.InvokeAsync(filter);
    }


    /* HELPERS */

    private string GetEmployeeValue()
        => State.SelectedEmployeeId?.ToString() ?? "0";

}