@using arna.HRMS.Components.Pages.Report.Component
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels
@using arna.HRMS.Components.lib.components.ui.CommonComponent
@using arna.HRMS.Components.lib.components.ui.Model
@using arna.HRMS.Services

@inject IEmployeeService EmployeeService

<div class="card border-0 shadow-sm rounded-3 mt-4">

    <div class="card-header bg-light">
        <strong>
            <i class="bi bi-table"></i>
            Attendance Report Table
        </strong>
    </div>

    <div class="card-body">

        <!-- FILTER BAR -->
        <div class="card border-0 shadow-sm rounded-3 mb-3">

            <div class="card-body py-2 px-3">

                <div class="row align-items-center g-2">

                    <div class="col-auto">
                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
                            <i class="bi bi-funnel-fill me-1"></i>
                            Filters
                        </span>
                    </div>

                    <div class="col d-flex justify-content-center">

                        <div class="d-flex align-items-center gap-3 flex-wrap">

                            <!-- YEAR MONTH -->
                            <div style="min-width:200px;">
                                <YearMonthPicker Year="year"
                                                 Month="month"
                                                 OnChange="OnDateChange" />
                            </div>

                            <!-- EMPLOYEE SEARCH -->
                            <div style="min-width:240px;">
                                <SearchEmployee Employees="EmployeeOptions"
                                                SelectedValue="@GetEmployeeValue()"
                                                OnChanged="OnEmployeeChange"
                                                OnNameChanged="OnEmployeeNameChanged" />
                            </div>

                            <!-- DEVICE DROPDOWN -->
                            <div style="min-width:200px;">
                                <select class="form-select"
                                        @bind="device"
                                        @bind:after="ApplyFilter">

                                    <option value="">All Devices</option>

                                    @foreach (var d in Enum.GetValues<DeviceType>())
                                    {
                                        <option value="@d">@GetDeviceName(d)</option>
                                    }

                                </select>
                            </div>

                            <!-- STATUS -->
                            <div style="min-width:180px;">
                                <select class="form-select"
                                        @bind="Status"
                                        @bind:after="ApplyFilter">

                                    <option value="">All Status</option>

                                    @foreach (var s in Enum.GetValues<AttendanceStatus>())
                                    {
                                        <option value="@s">@s</option>
                                    }

                                </select>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>


        <!-- TABLE -->
        <div class="table-responsive">

            <table class="table table-striped table-hover">

                <thead class="table-dark">

                    <tr>

                        <th>Employee No</th>
                        <th>Employee Name</th>
                        <th>Department</th>

                        <th>Date</th>
                        <th>Day</th>

                        <th>Total Hours</th>
                        <th>Working Hours</th>
                        <th>Break</th>

                        <th>Latitude</th>
                        <th>Longitude</th>

                        <th>Device</th>

                        <th>Status</th>

                    </tr>

                </thead>

                <tbody>

                    @if (ReportData == null)
                    {
                        <tr>
                            <td colspan="14" class="text-center text-muted">
                                Loading data...
                            </td>
                        </tr>
                    }
                    else if (!ReportData.Any())
                    {
                        <tr>
                            <td colspan="14" class="text-center text-danger fw-bold">
                                No data found
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in ReportData)
                        {
                            <tr>

                                <td>@(item.EmployeeNumber ?? "-")</td>
                                <td>@(item.EmployeeName ?? "-")</td>
                                <td>@(item.Department ?? "-")</td>

                                <td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td>
                                <td>@(item.Day ?? "-")</td>

                                <td>@FormatTimeSpan(item.TotalHours)</td>
                                <td>@FormatTimeSpan(item.WorkingHours)</td>
                                <td>@FormatTimeSpan(item.BreakDuration)</td>

                                <td>@(item.Latitude?.ToString() ?? "-")</td>
                                <td>@(item.Longitude?.ToString() ?? "-")</td>

                                <!-- DEVICE COLUMN -->
                                <td>@GetDeviceNames(item.Device)</td>

                                <td>@item.AttendanceStatus</td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>


@code {

    [Parameter] public List<AttendanceReportViewModel>? ReportData { get; set; }

    [Parameter] public EventCallback<AttendanceFilter> OnFilter { get; set; }

    int? year;
    int? month;
    int? employeeId;
    DeviceType? device;
    AttendanceStatus? Status;

    private string? _selectedEmployeeName;

    private List<SelectOption> EmployeeOptions = new();


    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    async Task OnEmployeeNameChanged(string? text)
    {
        _selectedEmployeeName = text;
    }


    private async Task LoadEmployees()
    {
        var result = await EmployeeService.GetEmployeesAsync();

        EmployeeOptions = result?.IsSuccess == true
            ? result.Data
                .Select(e => new SelectOption
                {
                    Value = e.Id.ToString(),
                    Text = $"{e.FullName} ({e.EmployeeNumber})"
                }).ToList()
            : new();
    }


    async Task OnDateChange((int year, int month) value)
    {
        this.year = value.year;
        this.month = value.month;

        await ApplyFilter();
    }


    async Task OnEmployeeChange(string? empId)
    {
        employeeId =
            !string.IsNullOrWhiteSpace(empId) && empId != "0"
            ? int.Parse(empId)
            : null;

        await ApplyFilter();
    }


    async Task ApplyFilter()
    {
        var filter = new AttendanceFilter
        {
            Year = year,
            Month = month,
            EmployeeId = employeeId,
            Device = device,
            Status = Status
        };

        await OnFilter.InvokeAsync(filter);
    }


    private string GetEmployeeValue()
        => employeeId?.ToString() ?? "0";


    string FormatTime(TimeSpan? time)
    {
        if (!time.HasValue)
            return "-";

        return time.Value.ToString(@"hh\:mm");
    }


    string FormatTimeSpan(TimeSpan? time)
    {
        if (!time.HasValue || time.Value == TimeSpan.Zero)
            return "-";

        return time.Value.ToString(@"hh\:mm");
    }


    string GetDeviceName(DeviceType device)
    {
        return device switch
        {
            DeviceType.Mobile => "Mobile",
            DeviceType.Tablet => "Tablet",
            DeviceType.LaptopDesktop => "Laptop / Desktop",
            DeviceType.UnknownDevice => "Unknown Device",
            _ => device.ToString()
        };
    }


    string GetDeviceNames(string? device)
    {
        if (string.IsNullOrWhiteSpace(device))
            return "-";

        var devices = device
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(x =>
            {
                if (Enum.TryParse<DeviceType>(x.Trim(), out var d))
                    return GetDeviceName(d);

                return "Unknown";
            });

        return string.Join(", ", devices);
    }

}