@page "/attendance-report"

@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels
@using arna.HRMS.Services.Report

@inject IReportService ReportService

<div class="container-fluid mt-4">

    <h3 class="fw-bold mb-3">
        <i class="bi bi-bar-chart-line"></i> Attendance Report
    </h3>

    <div class="mb-3">

        <select class="form-select w-auto"
                @bind="selectedGraph"
                @bind:after="GraphChanged">

            <option value="histogram">Work Hours</option>
            <option value="status">Attendance Status</option>
            <option value="table">Table View</option>

        </select>

    </div>


    @if (selectedGraph == "histogram")
    {
        <HistogramChart ReportData="reportData"
                        Year="year"
                        Month="month"
                        EmployeeId="employeeId"
                        OnFilter="LoadReport" />
    }

    @if (selectedGraph == "status")
    {
        <StatusBarChart ReportData="reportData"
                        Year="year"
                        Month="month"
                        EmployeeId="employeeId"
                        OnFilter="LoadReport" />
    }

    @if (selectedGraph == "table")
    {
        <AttendanceTable ReportData="reportData"
                         OnFilter="LoadReport" />
    }

</div>

@code {

    List<AttendanceReportViewModel> reportData = new();

    string selectedGraph = "histogram";

    int? year;
    int? month;
    int? employeeId;
    DeviceType? Device;
    AttendanceStatus? status;



    protected override async Task OnInitializedAsync()
    {
        await LoadReport(new AttendanceFilter());
    }



    async Task GraphChanged()
    {
        await LoadReport(new AttendanceFilter
        {
            Year = year,
            Month = month,
            EmployeeId = employeeId,
            Status = status,
            Device = Device
        });
    }



    async Task LoadReport(AttendanceFilter filter)
    {
        year = filter.Year;
        month = filter.Month;
        employeeId = filter.EmployeeId;
        status = filter.Status;
        Device = filter.Device;

        reportData = new List<AttendanceReportViewModel>();
        await InvokeAsync(StateHasChanged);

        var result = await ReportService.GetAttendanceReportAsync(
            year,
            month,
            employeeId,
            status,
            Device
        );

        if (result.IsSuccess && result.Data != null)
        {
            reportData = result.Data.ToList();
        }
        else
        {
            reportData = new List<AttendanceReportViewModel>();
        }

        await InvokeAsync(StateHasChanged);
    }

}