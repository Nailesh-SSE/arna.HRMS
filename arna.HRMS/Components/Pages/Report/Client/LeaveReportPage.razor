@page "/employee-leave-report"
@using arna.HRMS.Components.Loader
@using arna.HRMS.Components.Pages.Report.LeaveReport
@using arna.HRMS.Components.lib.components.ui.Forms
@using arna.HRMS.Models.Common.Table
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.ViewModels
@using arna.HRMS.Models.ViewModels.Attendance
@using arna.HRMS.Services
@using arna.HRMS.Services.Auth
@using arna.HRMS.Services.Report
@using arna.HRMS.Services.Common
@using Microsoft.AspNetCore.Components.Authorization

@inherits AuthenticatedLayoutBase
@inject IReportService ReportService
@inject IEmployeeService EmployeeService
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthProvider

@if (isLoading)
{
    <Loader Visible="isLoading" Message="Loading your Leave report…" />
}
else if (Employee == null)
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body text-center py-5">
            <div class="mb-3">
                <i class="bi bi-exclamation-triangle text-warning fs-1"></i>
            </div>
            <h5 class="fw-semibold text-muted mb-2">Employee Not Found</h5>
            <p class="text-muted mb-0">Unable to load your employee information. Please contact HR.</p>
        </div>
    </div>
}
else
{
    <LeaveDetailsReportPage Employee="Employee!" ShowBackButton="false" />
}

@code {

    private EmployeeViewModel? Employee;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            int empId = GetEmployeeId();

            // fallback from auth claims
            if (empId == 0)
            {
                var authState = await AuthProvider.GetAuthenticationStateAsync();
                var user = authState?.User;

                var empIdClaim = user?.FindFirst("EmployeeId")?.Value;

                if (!string.IsNullOrEmpty(empIdClaim) &&
                    int.TryParse(empIdClaim, out var claimEmpId))
                {
                    empId = claimEmpId;
                }
            }

            if (empId <= 0)
            {
                await NotificationService.Error("EmployeeId not found. Contact HR.");
                return;
            }

            var result = await EmployeeService.GetEmployeeByIdAsync(empId);

            if (result?.IsSuccess == true && result.Data != null)
            {
                Employee = result.Data;
            }
            else
            {
                await NotificationService.Error("Failed to load employee info.");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
