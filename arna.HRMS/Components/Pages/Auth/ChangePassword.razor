@page "/change-password"
@layout LoginLayout

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using arna.HRMS.Components.Layout
@using arna.HRMS.Components.lib.components.ui.Forms
@using arna.HRMS.Services
@using arna.HRMS.Services.Auth

@inject ILogger<ChangePassword> Logger
@inject NavigationManager NavigationManager
@inject IUserService UserService
@inherits AuthenticatedLayoutBase

<PageTitle>Arna Technosoft - Change Password</PageTitle>

<div class="container-fluid p-0">
    <div class="row g-0 min-vh-100">

        <!-- ══════════ LEFT BRAND PANEL (Desktop only) ══════════ -->
        <div class="col-lg-6 d-none d-lg-flex align-items-center
                    justify-content-center text-white position-relative
                    overflow-hidden cp-brand-bg">

            <div class="text-center p-5 position-relative z-1">

                <div class="bg-white bg-opacity-25 rounded-circle
                            d-inline-flex align-items-center
                            justify-content-center mb-4 p-4">
                    <i class="bi bi-shield-lock-fill display-3"></i>
                </div>

                <h2 class="fw-bold mb-3">Secure Your Account</h2>
                <p class="lead opacity-75 mb-4 px-4">
                    Keep your account safe by updating your
                    password regularly
                </p>

                <div class="d-flex gap-4 justify-content-center mt-4">
                    <div class="text-center">
                        <div class="bg-white bg-opacity-10 rounded-circle
                                    d-flex align-items-center justify-content-center
                                    mx-auto mb-2 cp-stat-icon">
                            <i class="bi bi-lock-fill fs-4"></i>
                        </div>
                        <small class="opacity-75">Strong</small>
                    </div>
                    <div class="text-center">
                        <div class="bg-white bg-opacity-10 rounded-circle
                                    d-flex align-items-center justify-content-center
                                    mx-auto mb-2 cp-stat-icon">
                            <i class="bi bi-shield-check fs-4"></i>
                        </div>
                        <small class="opacity-75">Secure</small>
                    </div>
                    <div class="text-center">
                        <div class="bg-white bg-opacity-10 rounded-circle
                                    d-flex align-items-center justify-content-center
                                    mx-auto mb-2 cp-stat-icon">
                            <i class="bi bi-key-fill fs-4"></i>
                        </div>
                        <small class="opacity-75">Private</small>
                    </div>
                </div>
            </div>

            <!-- Decorative shapes -->
            <div class="cp-shape cp-shape-1"></div>
            <div class="cp-shape cp-shape-2"></div>
        </div>

        <!-- ══════════ RIGHT FORM PANEL ══════════ -->
        <div class="col-12 col-lg-6 d-flex align-items-center
                    justify-content-center bg-light p-3 p-sm-4 p-lg-5">

            <div class="w-100 cp-form-container">

                <div class="card border-0 shadow rounded-4 overflow-hidden">

                    <!-- Accent bar -->
                    <div class="cp-accent-bar"></div>

                    <div class="card-body p-4 p-sm-5">
                        <!-- Logo & Title -->
                        <div class="text-center mb-4">
                            <div class="bg-warning bg-opacity-10 rounded-circle
                                        d-inline-flex align-items-center
                                        justify-content-center mb-3
                                        cp-logo-circle">
                                <i class="bi bi-shield-lock-fill fs-2
                                          text-warning"></i>
                            </div>
                            <h4 class="fw-bold mb-1">Change Password</h4>
                            <p class="text-muted small mb-0">
                                Create a strong password to secure your account
                            </p>
                        </div>

                        <!-- Success Alert -->
                        @if (!string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="alert alert-success border-0 rounded-3
                                            d-flex align-items-center gap-2
                                            py-2 px-3 small">
                                <i class="bi bi-check-circle-fill
                                              flex-shrink-0"></i>
                                <span>@successMessage</span>
                            </div>
                        }

                        <!-- Error Alert -->
                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="alert alert-danger border-0 rounded-3
                                            d-flex align-items-center gap-2
                                            py-2 px-3 small">
                                <i class="bi bi-exclamation-triangle-fill
                                              flex-shrink-0"></i>
                                <span>@errorMessage</span>
                                <AppButton Type="button"
                                        ButtonClass="btn-close ms-auto"
                                        Onclick="() => errorMessage = null"
                                        aria-label="Close">
                                </AppButton>
                            </div>
                        }

                        <!-- Form -->
                        <EditForm Model="@changePasswordModel"
                                  OnValidSubmit="HandleChangePassword">
                            <DataAnnotationsValidator />

                            <!-- New Password -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold small
                                              text-secondary">
                                    New Password
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white
                                                 border-end-0 text-muted">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <AppInput @bind-Value="changePasswordModel.NewPassword"
                                              Type="@passwordInputType"
                                              ShowWrapper="false"
                                              CssClass="border-start-0 border-end-0 ps-0"
                                              placeholder="Enter new password" />
                                    <AppButton Type="button"
                                            ButtonClass="btn btn-outline-light
                                                   border text-muted"
                                            Onclick="ToggleNewPasswordVisibility">
                                        <i class="bi @(showNewPassword
                                                                                       ? "bi-eye-slash"
                                                                                       : "bi-eye")"></i>
                                    </AppButton>
                                </div>
                                <ValidationMessage For="@(() => changePasswordModel.NewPassword)"
                                                   class="text-danger small mt-1" />
                            </div>

                            <!-- Confirm Password -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold small
                                              text-secondary">
                                    Confirm Password
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white
                                                 border-end-0 text-muted">
                                        <i class="bi bi-lock-fill"></i>
                                    </span>
                                    <AppInput @bind-Value="changePasswordModel.ConfirmPassword"
                                              Type="@confirmPasswordInputType"
                                              ShowWrapper="false"
                                              CssClass="border-start-0 border-end-0 ps-0"
                                              placeholder="Confirm new password" />
                                    <AppButton Type="button"
                                               ButtonClass="btn btn-outline-light
                                                   border text-muted"
                                            Onclick="ToggleConfirmPasswordVisibility">
                                        <i class="bi @(showConfirmPassword
                                                                                       ? "bi-eye-slash"
                                                                                       : "bi-eye")"></i>
                                    </AppButton>
                                </div>
                                <ValidationMessage For="@(() => changePasswordModel.ConfirmPassword)"
                                                   class="text-danger small mt-1" />
                            </div>

                            @* <!-- Password Tips -->
                            <div class="bg-body-secondary rounded-3 p-3 mb-4">
                                <p class="fw-semibold small mb-2 text-secondary">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Password Tips
                                </p>
                                <ul class="list-unstyled mb-0 small text-muted">
                                    <li class="mb-1">
                                        <i class="bi bi-check2 text-success me-1"></i>
                                        At least 6 characters long
                                    </li>
                                    <li class="mb-1">
                                        <i class="bi bi-check2 text-success me-1"></i>
                                        Include uppercase &amp; lowercase letters
                                    </li>
                                    <li>
                                        <i class="bi bi-check2 text-success me-1"></i>
                                        Include numbers or special characters
                                    </li>
                                </ul>
                            </div> *@

                            <!-- Buttons -->
                            <div class="d-grid gap-2">
                                <AppButton Type="submit"
                                        ButtonClass="btn btn-primary btn-lg
                                               fw-semibold rounded-3"
                                        disabled="@isLoading">
                                    @if (isLoading)
                                    {
                                        <span class="spinner-border
                                                         spinner-border-sm me-2"
                                              role="status"></span>
                                        <span>Updating…</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-shield-check me-2"></i>
                                        <span>Update Password</span>
                                    }
                                </AppButton>

                                <AppButton Type="button"
                                        ButtonClass="btn btn-outline-secondary
                                               rounded-3"
                                        Onclick="NavigateToHome"
                                        disabled="@isLoading">
                                    <i class="bi bi-house me-1"></i>
                                    Back to Home
                                </AppButton>
                            </div>
                        </EditForm>

                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-body-secondary border-0
                                text-center py-3">
                        <small class="text-muted">
                            <i class="bi bi-shield-lock-fill me-1
                                      text-success"></i>
                            Secured by
                            <span class="fw-semibold">Arna Technosoft</span>
                        </small>
                    </div>
                </div>

                <!-- Copyright -->
                <p class="text-center text-muted mt-3 mb-0 small">
                    &copy; @DateTime.Now.Year Arna Technosoft.
                    All rights reserved.
                </p>
            </div>
        </div>

    </div>
</div>

@code {
    private ChangePasswordModel changePasswordModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;
    private bool showNewPassword;
    private bool showConfirmPassword;

    private string passwordInputType =>
        showNewPassword ? "text" : "password";

    private string confirmPasswordInputType =>
        showConfirmPassword ? "text" : "password";

    private async Task HandleChangePassword()
    {
        errorMessage = null;
        successMessage = null;
        isLoading = true;

        try
        {
            var userId = GetUserId();
            if (userId == 0)
            {
                errorMessage = "Invalid user.";
                return;
            }

            var userData = await UserService.GetUserByIdAsync(userId);
            if (userData == null)
            {
                errorMessage = "User not found.";
                return;
            }

            if (changePasswordModel.NewPassword !=
                changePasswordModel.ConfirmPassword)
            {
                errorMessage =
                    "New password and confirm password do not match.";
                return;
            }

            var result = await UserService.ChangeUserPasswordAsync(
                userId, changePasswordModel.NewPassword);

            if (!result.IsSuccess)
            {
                errorMessage = "Failed to change password.";
                return;
            }

            successMessage =
                "Password changed successfully. Redirecting…";
            changePasswordModel = new ChangePasswordModel();
            StateHasChanged();

            await Task.Delay(1500);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Change password failed");
            errorMessage =
                "Something went wrong while changing the password.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToHome() =>
        NavigationManager.NavigateTo("/");

    private void ToggleNewPasswordVisibility() =>
        showNewPassword = !showNewPassword;

    private void ToggleConfirmPasswordVisibility() =>
        showConfirmPassword = !showConfirmPassword;

    public class ChangePasswordModel
    {
        [Required(ErrorMessage = "New password is required.")]
        [MinLength(6, ErrorMessage =
            "Password must be at least 6 characters.")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(NewPassword),
            ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}