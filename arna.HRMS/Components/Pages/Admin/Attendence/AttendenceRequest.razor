@page "/admin-attendance-requests"

@using arna.HRMS.Components.Loader
@using arna.HRMS.Components.lib.components.ui.Forms
@using arna.HRMS.Components.lib.components.ui.CommonComponent
@using arna.HRMS.Components.lib.components.ui.Model
@using arna.HRMS.Models.Common
@using arna.HRMS.Models.Common.Table
@using arna.HRMS.Models.Enums
@using arna.HRMS.Models.State.Attendance
@using arna.HRMS.Models.ViewModels.Attendance
@using arna.HRMS.Services
@using arna.HRMS.Services.Auth
@using arna.HRMS.Services.Common

@inject AttendanceState State
@inject IAttendanceRequestService AttendanceRequestService
@inject IEmployeeService EmployeeService
@inject NotificationService NotificationService
@inject IJSRuntime JsRuntime
@inherits AuthenticatedLayoutBase

<Loader Visible="_isLoading" Message="@_loadingMessage" />

@if (!_isLoading)
{
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h3 class="fw-bold mb-1 d-flex align-items-center">
                <i class="bi bi-inbox-fill text-primary me-2"></i>
                Attendance Requests
            </h3>
        </div>
    </div>

    <!-- ═══════════ FILTER BAR ═══════════ -->
    <div class="card border-0 shadow-sm rounded-3 mb-3 mb-md-4">
        <div class="card-body py-2 px-2 px-md-3">
            <div class="d-flex align-items-center flex-wrap gap-3">

                <div class="col-auto">
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill
                                         px-2 px-md-3 py-2">
                        <i class="bi bi-funnel-fill me-0 me-md-1"></i>
                        <span class="d-none d-md-inline">Filters</span>
                    </span>
                </div>

                <div class="col d-flex align-items-center gap-2">

                    <!-- Employee -->
                    <SearchEmployee Employees="Employees"
                                    SelectedValue="@GetEmployeeValue()"
                                    OnChanged="OnEmployeeChanged"
                                    OnNameChanged="OnEmployeeNameChanged" />

                    <!-- Status -->
                    <SearchStatus SelectedValue="_statusFilter"
                                  OnChanged="FilterByStatus" />

                </div>

                <div class="flex-grow-1"></div>

                @if (HasActiveFilters)
                {
                    <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick="ClearFilters">
                        <i class="bi bi-x-lg me-1"></i> Clear Filters
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- ═══════════ TABLE ═══════════ -->
    <div class="card border-0 shadow-sm rounded-3">

        <div class="card-header bg-white border-bottom py-2 py-md-3 px-2 px-md-3">
            <div class="d-flex align-items-center justify-content-between">
                <h6 class="fw-semibold mb-0 small">
                    <i class="bi bi-table text-primary me-1 me-md-2"></i>
                    <span class="d-none d-sm-inline">Request Details</span>
                    <span class="d-sm-none">Requests</span>
                </h6>
                <div class="d-flex align-items-center gap-2 gap-md-3">
                    @{
                        var pendingRequests = _allRequests.Count(r => r.StatusId == Status.Pending);
                    }
                    @if (pendingRequests > 0)
                    {
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="acceptAllSwitch"
                                   @bind="AcceptAllChecked"
                                   disabled="@_isUpdating" />
                            <label class="form-check-label small text-muted" for="acceptAllSwitch">
                                Accept all pending
                            </label>
                        </div>
                    }
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill
                                         px-2 px-md-3 small">
                        @FilteredRequests.Count
                        <span class="d-none d-sm-inline">requests</span>
                    </span>
                </div>
            </div>
        </div>

        <!-- ═══════════ ACCEPT ALL CONFIRMATION MODAL ═══════════ -->
        @if (_showAcceptAllModal)
        {
            <div class="modal d-block" style="background-color: rgba(0, 0, 0, 0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 rounded-3 shadow-lg">
                        <div class="modal-header border-0 bg-light rounded-top-3">
                            <h5 class="modal-title fw-semibold">
                                <i class="bi bi-exclamation-circle text-warning me-2"></i>
                                Accept All Pending Requests?
                            </h5>
                            <button type="button" class="btn-close" @onclick="OnAcceptAllCancel"></button>
                        </div>
                        <div class="modal-body py-3 py-md-4">
                            <p class="mb-2">
                                You are about to approve <strong>@(_allRequests.Count(r => r.StatusId == Status.Pending))</strong> pending attendance request(s).
                            </p>
                        </div>
                        <div class="modal-footer border-0 bg-light rounded-bottom-3 gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill"
                                    @onclick="OnAcceptAllCancel"
                                    disabled="@_isUpdating">
                                <i class="bi bi-x-lg me-1"></i>Cancel
                            </button>
                            <button type="button" class="btn btn-sm btn-success rounded-pill"
                                    @onclick="ApproveAllPendingAsync"
                                    disabled="@_isUpdating">
                                @if (_isUpdating)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Approving...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-circle me-1"></i>
                                    <span>Accept All</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card-body p-0">
            @if (!FilteredRequests.Any())
            {
                <div class="text-center py-4 py-md-5 px-3">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center
                                                justify-content-center mb-2 mb-md-3 empty-icon-circle">
                        <i class="bi bi-inbox fs-2 text-muted opacity-50"></i>
                    </div>
                    <h6 class="fw-semibold text-muted mb-1 fs-6">No Requests Found</h6>
                    <p class="text-muted small mb-2 mb-md-3 mx-auto empty-text">
                        @if (HasActiveFilters)
                        {
                            <span>No requests match your current filters.</span>
                        }
                        else
                        {
                            <span>There are no attendance requests yet.</span>
                        }
                    </p>
                    @if (HasActiveFilters)
                    {
                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3 px-md-4"
                                @onclick="ClearFilters">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="request-scroll-area">
                    <AppTable TItem="AttendanceRequestViewModel"
                              Items="FilteredRequests"
                              Columns="TableSchemas.AttendanceRequest"
                              EnablePagination="true"
                              PageSize="10"
                              WrapperClass="att-list-table">

                        <ActionTemplate Context="req">
                            @if (req.StatusId != Status.Cancelled)
                            {
                                <div class="d-flex align-items-center gap-1 gap-md-2
                                                                    justify-content-center">
                                    <button class="action-btn @GetApproveClass(req)"
                                            title="Approve"
                                            disabled="@_isUpdating"
                                            @onclick="() => UpdateStatus(req, Status.Approved)">
                                        <i class="bi bi-check-lg"></i>
                                    </button>

                                    <button class="action-btn @GetRejectClass(req)"
                                            title="Reject"
                                            disabled="@_isUpdating"
                                            @onclick="() => UpdateStatus(req, Status.Rejected)">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span class="req-status-icon req-icon-cancelled rounded-circle
                                                     d-inline-flex align-items-center justify-content-center"
                                      title="Cancelled">
                                    <i class="bi bi-slash-circle"></i>
                                </span>
                            }
                        </ActionTemplate>

                    </AppTable>
                </div>
            }
        </div>
    </div>
}

@code {
    // ═══════════ STATE ═══════════

    private bool _isLoading;
    private bool _isUpdating;
    private string _loadingMessage = "Loading attendance requests...";

    private List<AttendanceRequestViewModel> _allRequests = new();
    private List<SelectOption> Employees = new();

    private Status? _statusFilter;
    private string? _selectedEmployeeName;
    private string? _selectedEmployeeNumber;

    private int _pendingCount;
    private int _approvedCount;
    private int _rejectedCount;

    private bool _acceptAllChecked;
    private bool _showAcceptAllModal;

    // ═══════════ COMPUTED ═══════════

    private bool HasActiveFilters
        => _statusFilter.HasValue || State.SelectedEmployeeId.HasValue;

    private List<AttendanceRequestViewModel> FilteredRequests
        => _allRequests
            .Where(r =>
                (!_statusFilter.HasValue || r.StatusId == _statusFilter) &&
                (!State.SelectedEmployeeId.HasValue ||
                 r.EmployeeId == State.SelectedEmployeeId) &&
                (string.IsNullOrWhiteSpace(_selectedEmployeeName) ||
                 (r.EmployeeName?.Contains(_selectedEmployeeName,
                     StringComparison.OrdinalIgnoreCase) ?? false)))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _isLoading = true;

        try
        {
            // Ensure we start with no filters (shared AttendanceState may persist values across pages)
            _statusFilter = null;
            State.SelectedEmployeeId = null;
            State.SelectedEmployeeName = null;

            _selectedEmployeeName = null;
            _selectedEmployeeNumber = null;

            await Task.WhenAll(LoadEmployees(), LoadRequests());
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ═══════════ DATA ═══════════

    private async Task LoadRequests()
    {
        try
        {
            var result = await AttendanceRequestService.GetAllAsync();

            _allRequests = result?.IsSuccess == true
                ? result.Data ?? new()
                : new();

            RecalculateCounts();
        }
        catch
        {
            _allRequests = new();
            _pendingCount = _approvedCount = _rejectedCount = 0;
        }
    }

    private async Task LoadEmployees()
    {
        try
        {
            var result = await EmployeeService.GetEmployeesAsync();

            Employees = result?.IsSuccess == true && result.Data != null
                ? result.Data
                    .Select(e => new SelectOption
                    {
                        Value = e.Id.ToString(),
                        Text = $"{e.FullName} ({e.EmployeeNumber})"
                    })
                    .ToList()
                : new();
        }
        catch
        {
            Employees = new();
        }
    }

    private void RecalculateCounts()
    {
        _pendingCount = _allRequests.Count(r => r.StatusId == Status.Pending);
        _approvedCount = _allRequests.Count(r => r.StatusId == Status.Approved);
        _rejectedCount = _allRequests.Count(r => r.StatusId == Status.Rejected);
    }

    // ═══════════ EVENTS ═══════════

    private Task FilterByStatus(Status? status)
    {
        _statusFilter = status;
        return Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        _statusFilter = null;
        State.SelectedEmployeeId = null;
        _selectedEmployeeName = null;
        _selectedEmployeeNumber = null;
        await LoadRequests();
    }

    private async Task ClearEmployeeFilter()
    {
        State.SelectedEmployeeId = null;
        _selectedEmployeeName = null;
        _selectedEmployeeNumber = null;
        await LoadRequests();
    }

    private async Task OnEmployeeChanged(string? empId)
    {
        State.SelectedEmployeeId =
            !string.IsNullOrWhiteSpace(empId) && empId != "0"
                ? int.Parse(empId)
                : null;

        await LoadRequests();
    }

    private async Task OnEmployeeNameChanged(string? text)
    {
        _selectedEmployeeName = null;
        _selectedEmployeeNumber = null;

        if (!string.IsNullOrWhiteSpace(text))
        {
            var match = System.Text.RegularExpressions.Regex.Match(
                text, @"^(.*?)(?:\s*\((.*?)\))?$");

            if (match.Success)
            {
                _selectedEmployeeName = match.Groups[1].Value.Trim();
                _selectedEmployeeNumber = match.Groups[2].Value.Trim();
            }
        }

        await LoadRequests();
    }

    private async Task UpdateStatus(AttendanceRequestViewModel req, Status newStatus)
    {
        var action = newStatus == Status.Approved ? "approve" : "reject";

        var confirmed = await JsRuntime.InvokeAsync<bool>(
            "confirm",
            $"Are you sure you want to {action} this attendance request?");

        if (!confirmed) return;

        _isUpdating = true;
        StateHasChanged();

        try
        {
            var employeeId = GetEmployeeId();
            if (employeeId <= 0)
            {
                await NotificationService.Error("Unable to retrieve your employee ID. Please log in again.");
                return;
            }

            var result = await AttendanceRequestService
                .UpdateRequestStatusAsync(req.Id, newStatus, employeeId);

            if (result?.IsSuccess == true)
            {
                await NotificationService.Success($"Request {action}d successfully.");
                await LoadRequests();
                RecalculateCounts();
                StateHasChanged();
            }
            else
            {
                await NotificationService.Error(result?.Message ?? "Operation failed.");
            }
        }
        finally
        {
            _isUpdating = false;
        }
    }

    // ═══════════ HELPERS ═══════════

    private bool IsStatActive(Status? status) => _statusFilter == status;

    private string GetEmployeeValue()
        => State.SelectedEmployeeId?.ToString() ?? "0";

    private static string GetApproveClass(AttendanceRequestViewModel r)
        => r.StatusId == Status.Approved
            ? "btn btn-success shadow-sm"
            : "btn btn-outline-success";

    private static string GetRejectClass(AttendanceRequestViewModel r)
        => r.StatusId == Status.Rejected
            ? "btn btn-danger shadow-sm"
            : "btn btn-outline-danger";

    private static string TruncateName(string name, int maxLength)
        => name.Length <= maxLength ? name : $"{name[..maxLength]}…";

    // ═══════════ INNER TYPES ═══════════

    private record StatCardModel(
        Status? Status,
        string Icon,
        string BgClass,
        string TextClass,
        string ActiveClass,
        int Count,
        string Label);


    private async Task ApproveAllPendingAsync()
    {
        var pendingRequests = _allRequests.Where(r => r.StatusId == Status.Pending).ToList();

        if (!pendingRequests.Any())
        {
            await NotificationService.Warning("No pending requests to approve.");
            OnAcceptAllCancel();
            return;
        }

        _isUpdating = true;
        StateHasChanged();

        try
        {
            var employeeId = GetEmployeeId();
            if (employeeId <= 0)
            {
                await NotificationService.Error("Unable to retrieve your employee ID. Please log in again.");
                return;
            }

            int successCount = 0;
            int failCount = 0;

            foreach (var request in pendingRequests)
            {
                var result = await AttendanceRequestService
                    .UpdateRequestStatusAsync(request.Id, Status.Approved, employeeId);

                if (result?.IsSuccess == true)
                    successCount++;
                else
                    failCount++;
            }

            await LoadRequests();
            RecalculateCounts();
            StateHasChanged();

            if (failCount == 0)
            {
                await NotificationService.Success(
                    $"Successfully approved {successCount} request(s).");
            }
            else if (successCount == 0)
            {
                await NotificationService.Error(
                    $"Failed to approve {failCount} request(s). Please try again.");
            }
            else
            {
                await NotificationService.Warning(
                    $"Approved {successCount} request(s), but {failCount} failed.");
            }

            OnAcceptAllCancel();
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"Error approving requests: {ex.Message}");
        }
        finally
        {
            _isUpdating = false;
            StateHasChanged();
        }
    }

    private bool AcceptAllChecked
    {
        get => _acceptAllChecked;
        set
        {
            if (value)
            {
                var pendingCount = _allRequests.Count(r => r.StatusId == Status.Pending);
                if (pendingCount == 0)
                {
                    // reset and notify
                    _acceptAllChecked = false;
                    _ = NotificationService.Warning("No pending requests to approve.");
                    _ = InvokeAsync(StateHasChanged);
                    return;
                }

                _acceptAllChecked = true;
                _showAcceptAllModal = true;
            }
            else
            {
                _acceptAllChecked = false;
                _showAcceptAllModal = false;
            }

            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async void OnAcceptAllCancel()
    {
        AcceptAllChecked = false;
        _showAcceptAllModal = false;
        await InvokeAsync(StateHasChanged);
    }
}