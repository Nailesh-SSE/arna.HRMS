@using Microsoft.AspNetCore.Components.Authorization
@using arna.HRMS.Services.Auth

@inject IAuthService AuthService
@inherits AuthenticatedLayoutBase

<AuthorizeView>
    <Authorized>
        <div class="dropdown">

            <!-- ══════════ TRIGGER BUTTON ══════════ -->
            <button class="btn btn-light border rounded-pill
                           d-flex align-items-center gap-2 px-2 py-1
                           position-relative"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    aria-label="User menu">

                <!-- Avatar -->
                <span class="usermenu-avatar rounded-circle text-white
                             fw-bold d-flex align-items-center
                             justify-content-center flex-shrink-0">
                    @GetInitials()
                </span>

                <!-- Name + Role (md+) -->
                <div class="d-none d-md-flex flex-column lh-1
                            text-start me-1">
                    <span class="fw-semibold small text-truncate
                                 usermenu-name-width">
                        @GetUserName()
                    </span>
                    <span class="text-muted usermenu-role-text">
                        @GetRoleName()
                    </span>
                </div>

                <i class="bi bi-chevron-down d-none d-md-inline
                          text-muted usermenu-chevron-size"></i>

                <!-- Online dot -->
                <span class="position-absolute usermenu-online-dot
                             bg-success rounded-circle border
                             border-2 border-white">
                </span>
            </button>

            <!-- ══════════ DROPDOWN MENU ══════════ -->
            <ul class="dropdown-menu dropdown-menu-end shadow-lg
                       border-0 rounded-3 mt-2 py-0 overflow-hidden
                       usermenu-dropdown-width">

                <!-- Profile Header -->
                <li>
                    <div class="usermenu-profile-bg px-3 pt-3 pb-3">
                        <div class="d-flex align-items-center gap-3">

                            <!-- Large Avatar -->
                            <span class="usermenu-avatar-lg rounded-circle
                                         text-white fw-bold d-flex
                                         align-items-center
                                         justify-content-center
                                         flex-shrink-0 shadow-sm">
                                @GetInitials()
                            </span>

                            <div class="overflow-hidden">
                                <h6 class="fw-bold mb-0 text-truncate">
                                    @GetUserFullName()
                                </h6>
                            </div>
                        </div>
                    </div>
                </li>

                <li><hr class="dropdown-divider m-0" /></li>

                <!-- Menu Items -->
                <li>
                    <button class="dropdown-item d-flex align-items-center
                                   gap-2 py-2 px-3"
                            @onclick="@(() => Navigation.NavigateTo("/change-password"))">
                        <span class="usermenu-icon-circle bg-warning
                                     bg-opacity-10 rounded-circle
                                     d-flex align-items-center
                                     justify-content-center flex-shrink-0">
                            <i class="bi bi-lock text-warning"></i>
                        </span>
                        <div class="lh-sm">
                            <span class="fw-medium small">
                                Change Password
                            </span>
                            <br />
                            <span class="text-muted usermenu-sub-text">
                                Update your credentials
                            </span>
                        </div>
                    </button>
                </li>

                <li><hr class="dropdown-divider mx-3 my-1" /></li>

                <!-- Logout -->
                <li>
                    <button class="dropdown-item d-flex align-items-center
                                   gap-2 py-2 px-3 mb-1"
                            @onclick="HandleLogout"
                            disabled="@isLoggingOut">
                        <span class="usermenu-icon-circle bg-danger
                                     bg-opacity-10 rounded-circle
                                     d-flex align-items-center
                                     justify-content-center flex-shrink-0">
                            <i class="bi @(isLoggingOut ? "bi-hourglass-split" : "bi-box-arrow-right") text-danger"></i>
                        </span>
                        <div class="lh-sm">
                            <span class="fw-medium small text-danger">
                                @(isLoggingOut ? "Signing out..." : "Sign Out")
                            </span>
                            <br />
                            <span class="text-muted usermenu-sub-text">
                                End your session
                            </span>
                        </div>
                    </button>
                </li>
            </ul>
        </div>
    </Authorized>

    <NotAuthorized>
        <button class="btn btn-primary btn-sm rounded-pill px-3
                       d-flex align-items-center gap-1"
                @onclick="@(() => Navigation.NavigateTo("/login"))">
            <i class="bi bi-box-arrow-in-right"></i>
            <span class="d-none d-sm-inline">Sign In</span>
        </button>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isLoggingOut = false;

    private async Task HandleLogout()
    {
        try
        {
            isLoggingOut = true;
            Logger.LogInformation("User initiated logout");
            
            // ✅ Call AuthService which gets userId internally
            int userId = GetUserId();
            await AuthService.LogoutAsync(userId);
            
            Logger.LogInformation("Logout completed, redirecting to login");
            Navigation.NavigateTo("/login", true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Logout error in UserMenu");
            Navigation.NavigateTo("/login", true);
        }
        finally
        {
            isLoggingOut = false;
        }
    }

    private string GetInitials()
    {
        var name = GetUserFullName();
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : parts[0][0].ToString().ToUpper();
    }

    private string GetRoleName()
    {
        var role = GetUserRole();
        return string.IsNullOrWhiteSpace(role) ? "User" : role;
    }
}